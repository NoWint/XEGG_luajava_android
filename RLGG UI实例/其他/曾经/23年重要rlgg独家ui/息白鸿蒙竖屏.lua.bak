function changan.check2(cklist)
rest = {
	GridLayout,
	background = "#01010000",
	layout_width = '260dp',
	layout_height = "wrap_content",
	columnCount = '3',
	gravity = "center",
}
for i = 1,#cklist do
local name = cklist[i][1]
local func1 = cklist[i][2]
local func2 = cklist[i][3]
local nid = cklist[i][4]
if not name then name = "未设置" end
nid = name..guid()
local func = 开关(nid,func1,func2,nid)
_ENV[nid.."swc"] = luajava.loadlayout({
	LinearLayout,
	layout_width = '86dp',
	layout_height = "35dp",
	layout_marginTop = "4dp",
	layout_marginBottom = "0dp",
	layout_marginLeft = "0dp",
	layout_marginRight = "0dp",
	gravity = "center",
	{
		CheckBox,
		layout_width = '28dp',
		layout_height = "30dp",
		onClick = function()

		luajava.newThread(function() func() end):start() end,

	}, {
		TextView,
		gravity = "center",
		text = name,
		gravity = "center",
		textColor = txtco,
		layout_width = '58dp',
		layout_height = 'wrap_content',
	}})
rest[#rest+1] = _ENV[nid.."swc"]
end
return luajava.loadlayout(rest)
end

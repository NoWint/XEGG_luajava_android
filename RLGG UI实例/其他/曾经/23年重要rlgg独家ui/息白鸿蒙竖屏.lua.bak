}
h1{
    /* 文本透明 */
    color: transparent;
    font-size: 16px;
    /* 渐变背景 */
    background-image: -webkit-linear-gradient(92deg, #0050FF, #FF8AED);
    /* 裁剪掉文字以外的区域 */
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-size: 80%;
    background-repeat: repeat;
    background-position: center;
    /* 执行动画：动画名 时长 线性 无线播放 */

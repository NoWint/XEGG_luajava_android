function getButtonBG()
local selector = luajava.getStateListDrawable()
selector:addState({
	android.R.attr.state_pressed
}, getVerticalBG({0x55545454,0x55545454},15))
selector:addState({
	-android.R.attr.state_pressed
}, getVerticalBG({0x44ffffff,0x44ffffff},15,4,0xff232323))
return selector
end

function 获取图片(txt)
txt = string.url(txt,"de")
ntxt = string.sub(string.gsub(txt,"/","-"),-10,-1)
if string.find(tostring(txt),"http") ~= nil then
if panduan("/sdcard/长安1/图片/"..ntxt) == false then
file.download(txt,"/sdcard/长安1/图片/"..ntxt)
else
	if file.length("/sdcard/长安1/图片/"..ntxt) <= 1 then
file.download(txt,"/sdcard/长安1/图片/"..ntxt)
end
end
txt = "/sdcard/长安1/图片/"..ntxt
end
return luajava.getBitmapDrawable(txt)
end
function getRes(x)
return 获取图片("/sdcard/长安1/图片/"..x)
end

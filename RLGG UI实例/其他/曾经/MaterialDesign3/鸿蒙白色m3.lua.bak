Yunzhu.menu = function(sview)
  cebian = {
    LinearLayout,
    id = "侧边",
    layout_height = "match_parent",
    layout_width = "wrap_content",
    orientation = "horizontal",
    gravity = "center",
    elevation = "3dp",

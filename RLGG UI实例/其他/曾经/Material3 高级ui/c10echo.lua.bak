local webView = luajava.webView(function(webView)
	webView:loadData([[
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Document</title>
  <style>
    body {
      margin: 0;
      padding: 0;
      height: 100%;
      overflow: hidden;
      background: #f0f0f0; /* Light background */
      background-size:auto; 
    }

    .dynamic-island {
      position: fixed;
      top: 10px; /* Small offset from the top */
      left: 50%;
      transform: translateX(-50%);
      width: 30px;
      height: 30px;
      background-color: #000; /* Black background */
      border-radius: 50%;
      display: flex;
      justify-content: center;
      align-items: center;
      cursor: pointer;
      transition: 
        width 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94),
        height 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94),
        border-radius 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94),
        box-shadow 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94),
        transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
      box-shadow: 0 0 10px rgba(0, 0, 0, 0.3); /* Subtle shadow */
      overflow: hidden;
      z-index: 1000;
      text-align: center;
      padding: 5px;
      box-sizing: border-box;
    }

    .dynamic-island.active {
      width: 160px; /* Adjusted to maintain the same height as the circle's diameter */
      height: 30px;
      border-radius: 15px;
      background-color: rgba(0, 0, 0, 0.9);
      box-shadow: 0 0 15px rgba(0, 0, 0, 0.6);
    }

    .dynamic-island.expanded {
      width: 300px;
      height: 130px; /* Adjusted to fit the music player */
      border-radius: 15px;
    }

    .dynamic-island .content {
      color: white;
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 14px;
      text-align: center;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94), transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
      transform: scale(0.5);
    }

    .dynamic-island.active .content {
      opacity: 1;
      transform: scale(1);
      transition-delay: 0.15s;
    }

    .dynamic-island .state-text {
      margin-top: 20px;
      opacity: 0;
      transition: opacity 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94), transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
      transform: translateY(-10px);
    }

    .dynamic-island.active .state-text {
      opacity: 1;
      transform: translateY(0);
      transition-delay: 0.3s;
    }

    /* Music Player Styles */
    .music-player {
      display: none;
      opacity: 0;
      transition: opacity 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
      padding: 10px;
      box-sizing: border-box;
      position: absolute;
      bottom: 10px;
      left: 10px;
      width: calc(100% - 20px);
      height: calc(100% - 20px);
      background-color: rgba(0, 0, 0, 0.9);
      border-radius: 15px;
      color: white;
      font-family: 'Helvetica Neue', sans-serif;
      overflow: hidden;
    }

    .dynamic-island.expanded .music-player {
      display: block;
      opacity: 1;
    }

    .music-player .track-info {
      margin-bottom: 10px;
      text-align: center;
    }

    .music-player .track-info h2 {
      margin: 0;
      font-size: 16px;
    }

    .music-player .track-info p {
      margin: 5px 0 0 0;
      font-size: 12px;
      color: #bbb;
    }

    .music-controls {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 10px;
      padding: 0 20px;
    }

    .music-controls button {
      background: none;
      border: none;
      cursor: pointer;
      outline: none;
      transition: transform 0.3s ease;
    }

    .music-controls .prev,
    .music-controls .next {
      background-color: #fff;
      border-radius: 50%;
      width: 24px;
      height: 24px;
      margin: 0 5px;
    }

    .music-controls .play {
      width: 40px;
      height: 40px;
      border: 2px solid #fff;
      border-radius: 50%;
      position: relative;
    }

    .music-controls .play::after {
      content: '';
      position: absolute;
      top: 8px;
      left: 14px;
      width: 0;
      height: 0;
      border-style: solid;
      border-width: 10px 0 10px 16px;
      border-color: transparent transparent transparent #fff;
    }

    .music-player .progress-bar {
      width: 100%;
      height: 4px;
      background: #ddd;
      position: relative;
      top: -5px;
    }

    .music-player .progress-bar .progress {
      position: absolute;
      left: 0;
      top: 0;
      height: 100%;
      background: #004eff;
      width: 50%; /* Initial progress */
      transition: width 0.5s ease;
    }
  </style>
</head>
<body>

<div class="dynamic-island">
  <div class="content">
    <div class="state-text">
      <p>Dynamic Island</p>
    </div>
  </div>
  <div class="music-player">
    <div class="track-info">
      <h2>Song Title</h2>
      <p>Artist Name</p>
    </div>
    <div class="music-controls">
      <button class="prev"></button>
      <button class="play"></button>
      <button class="next"></button>
    </div>
    <div class="progress-bar">
      <div class="progress"></div>
    </div>
  </div>
</div>

<script>
  let activeIndex = 0; // To keep track of the current state
  const states = ['default', 'active', 'expanded'];
  const dynamicIsland = document.querySelector('.dynamic-island');
  const musicPlayer = document.querySelector('.music-player');
  const progressBar = document.querySelector('.progress');

  dynamicIsland.addEventListener('click', function() {
    // Remove existing active state
    dynamicIsland.classList.remove(...states);
    // Add next state
    activeIndex = (activeIndex + 1) % states.length;
    dynamicIsland.classList.add(states[activeIndex]);

    if (activeIndex === 2) {
      // When expanded, show the music player
      musicPlayer.style.display = 'block';
      musicPlayer.style.opacity = '1';
      progressBar.style.width = '50%'; // Set initial progress
    } else {
      // When not expanded, hide the music player
      musicPlayer.style.display = 'none';
    }
  });
</script>

</body>
</html>


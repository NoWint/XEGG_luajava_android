local t = {}
function t:addCardDemo(className, layout)
				self:addLayout({
					MaterialCardView,
					layout_width = 'match_parent',
					layout_height = 'wrap_content',
					layout_margin = "12dp",
					elevation = '8dp',
					{
						LinearLayout,
						layout_margin = "8dp",
						layout_width = 'match_parent',
						layout_height = 'wrap_content',
						orientation = 'vertical',
						{
							TextView,
							layout_width = 'match_parent',
							layout_height = 'wrap_content',
							text = className,
						},
						layout
					}
				})
			end
		
function t:submit(title)
				bottomTab:addLayout({
					title = title,
					{
						ScrollView,
						layout_width = 'match_parent',
						layout_height = 'match_parent',
						layouts
					}
				})
				bottomTab:notifyDataSetChanged()
			end

function getButtonBG()
local selector = luajava.getStateListDrawable()
selector:addState({
	android.R.attr.state_pressed
}, getVerticalBG({0x55000000,0x55000000},15))
selector:addState({
	-android.R.attr.state_pressed
}, getVerticalBG({0xaa1a1b1d,0xaa1a1b1d},15))
return selector
end


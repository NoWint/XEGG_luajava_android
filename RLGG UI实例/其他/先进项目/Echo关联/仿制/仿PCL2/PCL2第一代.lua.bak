function getButtonBG()
local selector = luajava.getStateListDrawable()
selector:addState({
	android.R.attr.state_pressed
}, getVerticalBG({0x55000000,0x55000000},35))
selector:addState({
	-android.R.attr.state_pressed
}, getVerticalBG({0xaa161616,0xaa161616},35))
return selector
end


		        if event:getAction() == MotionEvent.ACTION_DOWN then
		            -- 按下时执行的函数
		            recordtext:setText("正在录音")
		            luajava.newThread(function()
		            vibra:vibrate(30)
		            recorder = MediaRecorder()

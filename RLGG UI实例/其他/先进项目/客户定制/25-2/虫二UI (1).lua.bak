					id = luajava.newId(names),
					layout_width = '100dp',
					--layout_marginLeft = "5dp",
					layout_marginRight = "0dp",
				},
				{
					Slider,
					thumbHeight='23dp',
					trackHeight='15dp',
					trackStopIndicatorSize='0dp',
					tickVisible=false,
					__onFinish=function(v)
						v:setTrackActiveTintList(ColorStateList({{},},{0xffa0d3ee}))
						v:setTrackInactiveTintList(ColorStateList({{},},{0xffa0d3ee}))
						v:setThumbTintList(ColorStateList({{},},{0xffa0d3ee}))
						luajava.setInterface(v, 'addOnChangeListener',
						function(SeekBar, var2, var3)
							_ENV[bian] = var2
						end)
					end,
					layout_width = 'match_parent',
					id=luajava.newId(name.."seekbar"),
					valueFrom=smin,
					valueTo=smax,
					value=nows,
					stepSize=1.0,
				}
			}})
		luajava.getIdView(name..'seekbar'):setHaloRadius(100)--拖动时背景阴影大小
		return rest
	end




changan.button("热歌榜",
function()
 A="https://api.uomg.com/api/rand.music?sort=热歌榜&format=json"
Obtain=gg.makeRequest(A).content
muchen=Obtain:match('url":"(.-)","picurl')
name=Obtain:match('name":"(.-)","')
gg.alert('开始播放['..name..']')
gg.playMusic(muchen)
end),

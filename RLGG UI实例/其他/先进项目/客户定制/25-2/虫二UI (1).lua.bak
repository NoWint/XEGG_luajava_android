				layout_hight = "match_parent",
				layout_marginTop = "3dp",
				layout_marginBottom = "3dp",
				layout_marginLeft = "5dp" ,
				layout_marginRight = "5dp" ,
				gravity = "center_vertical",
				elevation='3dp',
				background = luajava.loadlayout {
					GradientDrawable ,
					color = 0x88ffffff ,
					cornerRadius = 15
				} ,padding = {

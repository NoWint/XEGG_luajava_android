-- 引入必要的库
require("import")
import "android.graphics.*"
import "android.graphics.drawable.*"
import "android.graphics.PorterDuff"
import "android.graphics.drawable.shapes.RoundRectShape"
import "android.graphics.Paint"
import "android.graphics.BitmapFactory"
import "android.renderscript.*"

-- 模糊函数：使用 RenderScript 进行图像模糊
function blurBitmap(bitmap, radius)
    local rs = RenderScript.create(activity)
    local input = Allocation.createFromBitmap(rs, bitmap)
    local output = Allocation.createTyped(rs, input.getType())
    local script = ScriptIntrinsicBlur.create(rs, Element.U8_4(rs))
    script.setRadius(radius)
    script.setInput(input)
    script.forEach(output)
    output.copyTo(bitmap)
    rs.destroy()
    return bitmap
end

-- 创建毛玻璃效果的 Drawable
function createFrostedGlassDrawable(width, height, radius, blurRadius)
    -- 创建 Bitmap 用于绘制毛玻璃效果
    local bitmap = Bitmap.createBitmap(width, height, Bitmap.Config.ARGB_8888)
    local canvas = Canvas(bitmap)

    -- 绘制半透明背景
    local paint = Paint()
    paint.setColor(0x80FFFFFF) -- 半透明白色 (128, 255, 255, 255)
    paint.setStyle(Paint.Style.FILL)
    canvas.drawRect(0, 0, width, height, paint)

    -- 应用模糊效果
    local blurredBitmap = blurBitmap(bitmap, blurRadius)

    -- 创建带有圆角的 Drawable
    local drawable = BitmapDrawable(activity.getResources(), blurredBitmap)
    local outerRadii = {radius, radius, radius, radius, radius, radius, radius, radius}
    local shapeDrawable = ShapeDrawable(RoundRectShape(outerRadii, nil, nil))
    shapeDrawable.getPaint().setShader(BitmapShader(blurredBitmap, Shader.TileMode.CLAMP, Shader.TileMode.CLAMP))
    shapeDrawable.getPaint().setColor(0x80FFFFFF) -- 半透明白色

    return shapeDrawable
end

-- 创建自定义 UI 控件
function createFrostedGlassView(width, height, radius, blurRadius)
    -- 创建 FrameLayout 作为容器
 
    -- 添加示例内容
    local text = TextView(activity)
    text.setText("毛玻璃效果控件")
    text.setTextColor(Color.BLACK)
    text.setTextSize(18)
    text.setPadding(20, 20, 20, 20)
    layout.addView(text)

    return layout
end

-- 显示自定义控件
function showFrostedGlassView()
    -- 获取屏幕尺寸
    

    -- 定义控件尺寸和圆角半径
    local width = "200dp"-- 50% 屏幕宽度
    local height = "200dp" --屏幕高度
    local radius = 50 -- 圆角半径
    local blurRadius = 15 -- 模糊半径

    -- 创建控件
    local view = createFrostedGlassView(width, height, radius, blurRadius)

    -- 创建 AlertDialog 来显示控件
    
end

-- 调用显示函数
showFrostedGlassView()
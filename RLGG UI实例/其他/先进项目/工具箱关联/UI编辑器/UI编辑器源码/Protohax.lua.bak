local rs = context:getResources():getDisplayMetrics()
rs = tostring(rs)
rs = string.gsub(rs, ',', ';')
rs = string.gsub(rs, 'DisplayMetrics', '')
load('rs=' .. rs)()
dheight = rs.height
dwidth = rs.width
if tonumber(dheight) == nil then
    dwidth = 1340
    dheight = 2300
end
if dheight > dwidth then dheight, dwidth = dwidth, dheight end

local dpi = rs.densityDpi
function getpx(x)
    if type(x) == 'string' then
        if string.find(x, 'dp') then
            x = string.gsub(x, 'dp', '')
            x = tonumber(x)
        end
        return x * (dpi / 160)
    else
        return x
    end
end
function panduan(rec) fille,err = io.open(rec) if fille == nil then return false else return true end end
function getdp(x)
    if type(x) == 'number' then
        return x / (dpi / 160) .. 'dp'
    else
        return x
    end
end
function 获取图片(txt)
    txt = string.url(txt,"de")
    if string.find(tostring(txt),"http") ~= nil then
    ntxt = string.sub(string.gsub(txt,"/","-"),-10,-1)
    if file.length("/sdcard/长安/图片/"..ntxt,false)<200 then
    file.download(txt,"/sdcard/长安/图片/"..ntxt)
    end
    txt = "/sdcard/长安/图片/"..ntxt
    end
    
    return luajava.getBitmapDrawable(txt)
    end
function getLayoutParams()
    LayoutParams = WindowManager.LayoutParams
    layoutParams = luajava.new(LayoutParams)
    if (Build.VERSION.SDK_INT >= 26) then
        layoutParams.type = LayoutParams.TYPE_APPLICATION_OVERLAY
    else
        layoutParams.type = LayoutParams.TYPE_PHONE
    end
    layoutParams.format = PixelFormat.RGBA_8888
    layoutParams.flags = LayoutParams.FLAG_NOT_TOUCH_MODAL
    layoutParams.gravity = Gravity.CENTER
    layoutParams.width = LayoutParams.MATCH_PARENT
    layoutParams.height = LayoutParams.MATCH_PARENT
    return layoutParams
end
function getLayoutParams2()
	local prm = luajava.new(WindowManager.LayoutParams)
	layoutParams1 = prm
	if (Build.VERSION.SDK_INT >= 26) then -- 设置悬浮窗方式
	layoutParams1.type = prm.TYPE_APPLICATION_OVERLAY
	else
		layoutParams1.type = prm.TYPE_PHONE
	end
	layoutParams1.format = PixelFormat.RGBA_8888 -- 设置背景
	layoutParams1.flags = prm.FLAG_NOT_FOCUSABLE -- 焦点设置Finish
	layoutParams1.gravity = Gravity.LEFT|Gravity.TOP -- 重力设置
	layoutParams1.width = prm.WRAP_CONTENT -- 布局宽度
	layoutParams1.height = prm.WRAP_CONTENT -- 布局高度
	return layoutParams1
end
params2=getLayoutParams2() 
mainLayoutParams = getLayoutParams()
function getVerticalBG(gtvb1,gtvb3,gtvb4,gtvb5)
    if not gtvb4 then gtvb4 = 0 gtvb5 = 0xff000000 end
    local jianbians = luajava.loadlayout({GradientDrawable})
    jianbians:setCornerRadius(gtvb3)
    jianbians:setGradientType(GradientDrawable.LINEAR_GRADIENT)
    jianbians:setColors(gtvb1)
    jianbians:setStroke(gtvb4,gtvb5)--边框宽度和颜色
    return jianbians
end
wanqi.controlBig = function(control, time)
    luajava.runUiThread(function()
        ObjectAnimator():ofFloat(control, "scaleX", {
            0, 0.4, 0.7, 1
        }):setDuration(time):start()
        ObjectAnimator():ofFloat(control, "scaleY", {
            0, 0.4, 0.7, 1
        }):setDuration(time):start()
    end)
end
wanqi.controlFlip = function(control, time)
    luajava.runUiThread(function()
        xuanzhuandonghua = ObjectAnimator:ofFloat(control, "rotationY", {
            0, 360
        })
        xuanzhuandonghua:setRepeatCount(0)
        xuanzhuandonghua:setRepeatMode(Animation.REVERSE)
        xuanzhuandonghua:setDuration(time)
        xuanzhuandonghua:start()
    end)
end
wanqi.controlWater = function(control, time)
    luajava.runUiThread(function()
        ObjectAnimator():ofFloat(control, "scaleX", {
            1, 0.8, 0.9, 1
        }):setDuration(time):start()
        ObjectAnimator():ofFloat(control, "scaleY", {
            1, 0.8, 0.9, 1
        }):setDuration(time):start()
    end)
end
wanqi.controlSmall = function(control, time)
    luajava.runUiThread(function()
        ObjectAnimator():ofFloat(control, "scaleX", {
            1, 0.7, 0.4, 0
        }):setDuration(time):start()
        ObjectAnimator():ofFloat(control, "scaleY", {
            1, 0.7, 0.4, 0
        }):setDuration(time):start()
    end)
end
YoYoImpl = luajava.getYoYoImpl()
wanqi.menu=function(sview)
    hanshu = function(v, event)
        local view=xfc
        local Action = event:getAction()
        if Action == MotionEvent.ACTION_DOWN then
            isMove = false
            RawX = event:getRawX()
            RawY = event:getRawY()
            x = params2.x
            y = params2.y
        elseif Action == MotionEvent.ACTION_MOVE then
            isMove = true
            params2.x = tonumber(x) + (event:getRawX() - RawX)
            if params2.x <= 0 then
                params2.x = 0
            end
            params2.y = tonumber(y) + (event:getRawY() - RawY)
            window:updateViewLayout(view, params2)
        elseif Action == MotionEvent.ACTION_UP then
            params2.x = tonumber(x) + (event:getRawX() - RawX)
            if params2.x <= 0 then
                params2.x = 0
            end
            params2.y = tonumber(y) + (event:getRawY() - RawY)
            window:updateViewLayout(view, params2)
            if math.abs(params2.x - x) >= 10 or math.abs(params2.y - y) >= 10 then
                return true
            else
    
            end
        end
    end
    cebian={
        LinearLayout,
        layout_width='90dp',
        layout_height='wrap_content',
        orientation='vertical',
        gravity='center_horizontal',
                  {
            NavigationRailView,
            layout_width = "70dp", -- 侧边导航通常是 `wrap_content`
            layout_height = "match_parent",
            LabelVisibilityMode = 0,  --1 是否显示标签	
            elevation="3dp",
           -- layout_height = "77dp",
            LabelVisibilityMode = 0,  --1 是否显示标签	
            background = getVerticalBG({0xffFEF7FF, 0xffFEF7FF}, 10),
            __onFinish = function(view)
    		view:setItemTextColor(ColorStateList({{android.R.attr.state_checked},{}},{"0xff"..RGBcolor,0xFF44474E}))          
		    view:setItemIconTintList(ColorStateList({{android.R.attr.state_checked},{}},{"0xff"..RGBcolor,0xFF44474E}))
		    view:setItemRippleColor(ColorStateList({{android.R.attr.state_checked},{}},{"0x35"..RGBcolor,"0x35"..RGBcolor}))
	    	view:setItemActiveIndicatorColor(ColorStateList({{android.R.attr.state_checked},{}},{"0x50"..RGBcolor,"0x50"..RGBcolor}))            
            local menu = view:getMenu()
            --[[
            for i = 1,3 do
            local item = menu:add(0, i, i, "预览" .. 1) -- 添加菜单项
            item:setIcon(MDC_R.drawable.abc_ic_search_api_material) -- 设置默认图标
            end
            ]]
              local item = menu:add(0, 1, 1, "云烛" .. 1) -- 添加菜单项
            item:setIcon(MDC_R.drawable.abc_ic_search_api_material) -- 设置默认图标
              local item = menu:add(0, 2, 2, "云烛" .. 2) -- 添加菜单项
            item:setIcon(MDC_R.drawable.abc_ic_search_api_material) -- 设置默认图标
              local item = menu:add(0, 3, 3, "云烛" .. 3) -- 添加菜单项
            item:setIcon(MDC_R.drawable.abc_ic_search_api_material) -- 设置默认图标
        end
    },
    }
    local layout = {
		'ui.VerticalViewPager',
		layout_height='match_parent',
		layout_width='match_parent',
	}
--[[
    for i = 1,#stab do
        table.insert(cebian,{
            LinearLayout,
            layout_width='match_parent',
            layout_height='wrap_content',
            orientation='vertical',
            gravity='center_horizontal',
            padding='5dp',
            onClick=function(v)
	            ViewPagerV:setCurrentItem(i-1)
            end,
            {
                ImageView,
                id=luajava.newId('jm'..i..'p'),
                layout_width='match_parent',
                layout_height='30dp',
                src=获取图片(stab[i][2]),
                colorFilter=0xff545454,
            },{
                TextView,
                id=luajava.newId('jm'..i..'t'),
                gravity='center',
                text=stab[i][1],
                textSize='10sp',
                textColor=0xff545454,
            }
        })
        local tmp={
            LinearLayout,
            id=luajava.newId("layoutm"..i),
            orientation="vertical",
            layout_width="match_parent",
            layout_height="wrap_content",
            }
            for j=1,#sview[i] do
                table.insert(tmp,sview[i][j])
            end
            table.insert(layout,{
                NestedScrollView,
                __onFinish=function(v)
                    _ENV['layout'..i]=v
                    v:setVerticalScrollBarEnabled(false)
                end,
                layout_width="match_parent",
                layout_height="wrap_content",
                tmp
            })
    end
    ViewPager = ui.VerticalViewPager(layout)
    ViewPagerV=ViewPager
	luajava.setInterface(ViewPager, 'addOnPageChangeListener', 
		{onPageSelected=function(view)
		当前ui=view+1
		切换(当前ui)
		end})
		]]
    floatWindow=luajava.loadlayout(
        {
            LinearLayout,
            layout_width='wrap_content',
            layout_height='wrap_content',
            orientation='horizontal',
            gravity='center',
            padding='30dp',
            background='#33000000',
            onClick=function (v)
                luajava.startThread(function()
                    luajava.runUiThread(function()
                        YoYoImpl:with("FadeOut"):duration(400):playOn(floatWindow)
                    end)
                    gg.sleep(400)
                    luajava.runUiThread(function()
                        v:setVisibility(View.GONE)
                    end)
                end)
                xfc:setVisibility(View.VISIBLE)
            end,
            
            {
                LinearLayout,
                layout_width='match_parent',
                layout_height='match_parent',
                orientation='horizontal',
                gravity='center_vertical',
                background=getVerticalBG({0xfffafafc,0xfffafafc},20),
                onClick=function(v) end,
                cebian,
                {
                    LinearLayout,
                    layout_width='match_parent',
                    layout_height='match_parent',
                    orientation='vertical',
                    gravity='left',
                    layout_weight=1,
                    background=getVerticalBG({0xffd8dff7,0xffd8dff7},20),
                    padding='10dp',
                    
                }
            },
        }
    )
    xfc=luajava.loadlayout(
        {
            LinearLayout,
            visibility='gone',
            onClick=function (v)
                v:setVisibility(View.GONE)
                YoYoImpl:with("FadeIn"):duration(600):playOn(floatWindow)
                floatWindow:setVisibility(View.VISIBLE)
            end,
            onTouch=hanshu,
            {
                ImageView,
                layout_height='40dp',
                layout_width='40dp',
                src=获取图片(xfcpic),
            }
        }
    )
    切换(1)
    luajava.post(function()
        window:addView(floatWindow,mainLayoutParams)
        window:addView(xfc,params2)
    end)
    setOnExitListener(function()
        luajava.post(function()
            window:removeView(floatWindow)
            window:removeView(xfc)
        end)
        luajava.setFloatingWindowHide(false)
        luajava.setFloatingWindowHide(false)
        gg.setVisible(true)
        bloc('end')
    end)
    bloc=luajava.getBlock()
    bloc('join')
end
slcta=getVerticalBG({0xffD7E1F8,0xffD7E1F8},90)
function 切换(x)
    for i=1,#stab do
        if x~=i then
            luajava.getIdView('jm'..i..'p'):setBackground(nil)
            luajava.getIdView('jm'..i..'p'):setColorFilter(0xff545454)
            luajava.getIdView('jm'..i..'t'):setTextColor(0xff545454)
        else
            print('jm'..i..'p')
            luajava.getIdView('jm'..i..'p'):setBackground(slcta)
            luajava.getIdView('jm'..i..'p'):setColorFilter(0xff101a31)
            luajava.getIdView('jm'..i..'t'):setTextColor(0xff101a31)
        end
    end
end




function Yunzhu.texta(text,color,size,isjz)
	if not color then color="#161616" end
	if isjz then
		return luajava.loadlayout(
		{
			TextView,
			text=text,
			textColor=color,
			textSize=size,
			gravity="center",
			layout_height="wrap_content",
			layout_width="match_parent",
			autoSizeTextType="uniform",
		})
		else
		return luajava.loadlayout({
			TextView,
			text=text,
			textColor=color,
			textSize=size,
			layout_height="wrap_content",
			layout_width="match_parent",
			autoSizeTextType="uniform",
		})
	end
end



-- 封装可实时更新的文本框控件
function Yunzhu.dynamicText(initText, color, size, isCenter)
    -- 默认参数处理
    if not initText then initText = "" end
    if not color then color = "#161616" end
    if not size then size = "16sp" end
    
    -- 创建布局参数
    local layoutParams = {
        TextView,
        text = initText,
        textColor = color,
        textSize = size,
        padding = "12dp",
        layout_height = "wrap_content",
        layout_width = "match_parent",
        autoSizeTextType = "uniform"
    }
    
    -- 居中处理
    if isCenter then
        layoutParams.gravity = "center"
    end
    
    -- 创建TextView
    local textView = luajava.loadlayout(layoutParams)
    
    -- 添加更新方法
    textView.updateText = function(newText)
        textView.text = newText
    end
    
    -- 添加颜色更新方法
    textView.updateColor = function(newColor)
        textView.textColor = newColor
    end
    
    -- 添加大小更新方法
    textView.updateSize = function(newSize)
        textView.textSize = newSize
    end
    
    return textView
end

--[[
local myText = Yunzhu.dynamicText("初始文本", "#FF0000", "20sp", true)

-- 添加到布局中（假设有一个父布局叫mainLayout）
mainLayout.addView(myText)


-- 定时更新文本示例
local counter = 0
timers.setInterval(function()
    counter = counter + 1
    myText.updateText("更新次数: "..counter)
    
    -- 随机改变颜色
    local r = math.random(0, 255)
    local g = math.random(0, 255)
    local b = math.random(0, 255)
    myText.updateColor(string.format("#%02X%02X%02X", r, g, b))
end, 1000)

-- 保持脚本运行

]]

function Yunzhu.text(text,color,size,isjz)
	if not color then color="#161616" end
	if isjz then
		return luajava.loadlayout(
		{
			TextView,
			text=text,
			textColor=color,
			textSize=size,
			gravity="left",
			padding="12dp",
			layout_height="wrap_content",
			layout_width="match_parent",
			autoSizeTextType="uniform",
		})
		else
		return luajava.loadlayout({
			TextView,
			text=text,
			textColor=color,
			textSize=size,
			padding="12dp",
			layout_height="wrap_content",
			layout_width="match_parent",
			autoSizeTextType="uniform",
		})
	end
end

function 灵动岛开关(name,func1,func2,nid)
name = name..guid()
_ENV[name] = "关"
if func1 == nil then func1 = function() end end
if func2 == nil then func2 = function() end end
if type(func1) == "function" then
return function()
namers = _ENV[name]
if namers ~= "开" then
luajava.runUiThread(function()	
	luajava.getIdValue(nid.."k"):setBackground(getHorizontalBG({0x00C24C38,0x00F78F5C},5))
	luajava.getIdValue(nid.."g"):setBackground(getHorizontalBG({"0xffff0000","0xffff0000","0xffff0000"},5,3,"0xffff0000"))
	end)
_ENV[name] = "开"
vibra:vibrate(6)
pcall(func1)
else
	luajava.runUiThread(function()
	luajava.getIdValue(nid.."g"):setBackground(getHorizontalBG({0x00C24C38,0x00F78F5C},5))
	luajava.getIdValue(nid.."k"):setBackground(getHorizontalBG({"0xffff0000","0xffff0000","0xffff0000"},5,3,"0xffff0000"))
	end)
_ENV[name] = "关"
vibra:vibrate(6)
pcall(func2)
end
end
end
end
	function getButtonBG()
		local selector = luajava.getStateListDrawable()
		selector:addState({
			android.R.attr.state_pressed
		}, getVerticalBG({0x55d7d7d7,0x55d7d7d7},20))
		selector:addState({
			-android.R.attr.state_pressed
		}, getHorizontalBG({0xff141218,0xff141218},40,3,0xff49454F))
		return selector
	end

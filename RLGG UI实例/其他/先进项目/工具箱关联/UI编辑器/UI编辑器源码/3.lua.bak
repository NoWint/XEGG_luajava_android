                 progress={type="number", default=50, min=0, max=100},
                 style={type="choice", options={"horizontal","circular"}, default="horizontal"}
             }},
            {type="SeekBar",         name="拖动条",     icon="🎚️",
             properties={
                 progress={type="number", default=50, min=0, max=100},
                 thumb={type="color", default="#FFFFFFFF"}
             }},
            
            -- 高级组件
            {type="RecyclerView",    name="回收视图",   icon="♻️",
             properties={
                 layoutManager={type="choice", options={"linear","grid","staggered"}, default="linear"},
                 itemCount={type="number", default=10, min=1, max=100}
             }},
            {type="ViewPager",       name="视图翻页",   icon="📖",
             properties={
                 offscreenPageLimit={type="number", default=1, min=1, max=5},
                 pageMargin={type="number", default=0, min=0, max=100}
             }},
            {type="WebView",         name="网页视图",   icon="🌐",
             properties={
                 url={type="text", default="https://"},
                 javaScriptEnabled={type="boolean", default=true}
             }},
            
            -- 导航组件
            {type="BottomNavigationView", name="底部导航", icon="⬇️",
             properties={
                 menu={type="items", default={"首页","分类","我的"}},
                 itemIconTint={type="color", default="#FFFFFFFF"},
                 itemTextColor={type="color", default="#FFFFFFFF"}
             }},
            {type="Toolbar",         name="工具栏",     icon="🛠️",
             properties={
                 title={type="text", default="应用标题"},
                 titleTextColor={type="color", default="#FFFFFFFF"},
                 background={type="color", default="#FF2196F3"}
             }}
        },
        
        dialogs = {
            {type="AlertDialog",     name="提示对话框", icon="💬",
             properties={
                 title={type="text", default="提示标题"},
                 message={type="text", default="对话框内容"},
                 positiveButton={type="text", default="确定"},
                 negativeButton={type="text", default="取消"}
             }},
            {type="BottomSheetDialog", name="底部弹窗", icon="📥",
             properties={
                 peekHeight={type="number", default=200, min=100, max=1000},
                 halfExpandedRatio={type="number", default=0.5, min=0.1, max=1}
             }}
        }
    },
    
    _ATTRIBUTES = {
        size = {"layout_width", "layout_height", "minWidth", "minHeight"},
        margin = {"layout_margin", "layout_marginLeft", "layout_marginTop", "layout_marginRight", "layout_marginBottom"},
        padding = {"padding", "paddingLeft", "paddingTop", "paddingRight", "paddingBottom"},
        background = {"background", "foreground", "backgroundTint"},
        text = {"text", "hint", "textSize", "textColor", "textStyle"},
        gravity = {"gravity", "layout_gravity"},
        weight = {"layout_weight", "weightSum"},
        advanced = {"elevation", "translationZ", "rotation"}
    }
}

--[[ 初始化方法 ]]--
function UIEditor:new(config)
    local obj = {
        currentLayout = nil,
        config = {
            outputPath = "/sdcard/Yunzhu编辑器/",
            defaultFile = "ui_layout.lua",
            theme = {
                primaryColor = "#FF2196F3",
                backgroundColor = "#FF303030",
                textColor = "#FFFFFFFF"
            }
        },
        history = {},
        componentCache = {}
    }
    
    if config then
        for k, v in pairs(config) do
            if type(v) == "table" then
                obj.config[k] = v
            else
                obj.config[k] = v
            end
        end
    end
    
    setmetatable(obj, self)
    self.__index = self
    return obj
end

--[[ 核心工作流 ]]--
function UIEditor:start()
    self:initWorkspace()
    self:showMainMenu()
end

function UIEditor:initWorkspace()
    if not file.checkDir(self.config.outputPath) then
        gg.alert("无法创建输出目录："..self.config.outputPath)
        os.exit()
    end
    gg.toast("工作区已初始化", false)
end

--[[ 主菜单系统 ]]--
function UIEditor:showMainMenu()
    while true do
        local menuItems = {
            "📐 创建新布局",
            "✏️ 编辑当前布局",
            "🧩 添加组件",
            "⚙️ 编辑组件属性",
            "👁️ 实时预览",
            "💾 生成代码",
            "📂 打开保存的布局",
            "⚙️ 编辑器设置",
            "📜 操作历史",
            "🚪 退出"
        }
        
        local choice = gg.choice(menuItems, nil, "云烛RLGG UI编辑器 v"..self._VERSION)
        
        if choice == 1 then
            self:createNewLayout()
        elseif choice == 2 then
            self:editCurrentLayout()
        elseif choice == 3 then
            self:addComponent()
        elseif choice == 4 then
            self:editComponentProperties()
        elseif choice == 5 then
            self:previewUI()
        elseif choice == 6 then
            self:generateAndSaveCode()
        elseif choice == 7 then
            self:loadLayout()
        elseif choice == 8 then
            self:showEditorSettings()
        elseif choice == 9 then
            self:showHistory()
        elseif choice == 10 then
            break
        end
    end
end

--[[ 布局创建 ]]--
function UIEditor:createNewLayout()
    local layoutTypes = {}
    for _, layout in ipairs(self._CONTROLS.layouts) do
        table.insert(layoutTypes, layout.icon.." "..layout.name)
    end

    local choice = gg.choice(layoutTypes, nil, "选择布局类型")
    if choice then
        local layoutDef = self._CONTROLS.layouts[choice]
        self.currentLayout = {
            type = layoutDef.type,
            children = {},
            properties = self:getDefaultProperties(layoutDef.properties),
            metadata = {
                created = os.date("%Y-%m-%d %H:%M:%S"),
                modified = os.date("%Y-%m-%d %H:%M:%S")
            }
        }
        self:recordHistory("创建 "..layoutDef.name)
        gg.toast(layoutDef.name.." 创建成功", false)
    end
end

--[[ 组件管理 ]]--
function UIEditor:addComponent()
    if not self.currentLayout then
        gg.alert("请先创建或加载布局")
        return
    end

    local widgetCategories = {
        "📄 基础控件", "✅ 选择控件", "📈 进度控件",
        "🔄 高级组件", "🗺️ 导航组件", "💬 对话框"
    }
    
    local choice = gg.choice(widgetCategories, nil, "选择组件类别")
    local widgetList = {}
    
    if choice == 1 then
        widgetList = self._CONTROLS.widgets[1].type == "TextView" and self._CONTROLS.widgets or {}
    elseif choice == 2 then
        -- 选择控件逻辑
    end
    
    -- 组件选择逻辑（因篇幅限制简化处理）
    local selectedWidget = self._CONTROLS.widgets[1]
    local newComponent = {
        type = selectedWidget.type,
        properties = self:getDefaultProperties(selectedWidget.properties),
        metadata = {
            position = #self.currentLayout.children + 1,
            added = os.date("%Y-%m-%d %H:%M:%S")
        }
    }
    table.insert(self.currentLayout.children, newComponent)
    gg.toast(selectedWidget.name.." 添加成功", false)
end

--[[ 属性编辑系统 ]]--
function UIEditor:editComponentProperties()
    if not self.currentLayout then
        gg.alert("当前没有可编辑的布局")
        return
    end

    local components = {}
    for i, comp in ipairs(self.currentLayout.children) do
        table.insert(components, string.format("%s #%d", comp.type, i))
    end
    table.insert(components, "🔙 返回")

    while true do
        local choice = gg.choice(components, nil, "选择要编辑的组件")
        if not choice or components[choice] == "🔙 返回" then break end
        
        local selected = self.currentLayout.children[choice]
        local widgetDef
        for _, w in ipairs(self._CONTROLS.widgets) do
            if w.type == selected.type then
                widgetDef = w
                break
            end
        end

        if widgetDef then
            self:showAttributeEditor(selected, widgetDef.properties)
        end
    end
end

function UIEditor:showAttributeEditor(component, propertiesDef)
    while true do
        local attrList = {"🔙 返回"}
        for attrName, _ in pairs(propertiesDef) do
            table.insert(attrList, 1, attrName)
        end

        local choice = gg.choice(attrList, nil, "编辑属性 - "..component.type)
        if not choice or attrList[choice] == "🔙 返回" then break end
        
        local attrName = attrList[choice]
        local propDef = propertiesDef[attrName]
        local currentValue = component.properties[attrName]

        -- 根据属性类型处理输入
        if propDef.type == "choice" then
            local newChoice = gg.choice(propDef.options, nil, "选择 "..attrName)
            if newChoice then
                component.properties[attrName] = propDef.options[newChoice]
            end
        elseif propDef.type == "color" then
            local color = gg.colorPicker(currentValue)
            if color then
                component.properties[attrName] = color
            end
        elseif propDef.type == "function" then
            local code = gg.prompt({"输入Lua函数代码"}, {currentValue or ""}, {"text"})
            if code and code[1] ~= "" then
                component.properties[attrName] = code[1]
            end
        else
            local inputType = propDef.type == "number" and "number" or "text"
            local result = gg.prompt({"设置 "..attrName}, {tostring(currentValue)}, {inputType})
            if result then
                component.properties[attrName] = propDef.type == "number" and tonumber(result[1]) or result[1]
            end
        end
    end
end

--[[ 代码生成与预览 ]]--
function UIEditor:generateCode()
    if not self.currentLayout then return nil end
    
    local code = {
        "local luajava = require('luajava')",
        "return function(context)",
        "    return luajava.loadlayout({"
    }

    local function processComponent(comp, indent)
        local indentStr = string.rep("    ", indent)
        table.insert(code, indentStr..comp.type..",")
        
        for prop, value in pairs(comp.properties) do
            local propLine
            if prop == "onClick" then
                propLine = string.format('%sonClick = %s,', indentStr.."    ", value)
            elseif type(value) == "string" and value:match("^#") then
                propLine = string.format('%s%s = "%s",', indentStr.."    ", prop, value)
            else
                propLine = string.format('%s%s = %s,', indentStr.."    ", prop, tostring(value))
            end
            table.insert(code, propLine)
        end

        if comp.children then
            for _, child in ipairs(comp.children) do
                table.insert(code, indentStr.."    {")
                processComponent(child, indent + 2)
                table.insert(code, indentStr.."    },")
            end
        end
    end

    processComponent(self.currentLayout, 1)
    table.insert(code, "    }, nil, context)")
    table.insert(code, "end")

    return table.concat(code, "\n")
end

function UIEditor:previewUI()
    local code = self:generateCode()
    if not code then return end

    local tempFunc, err = load(code)
    if not tempFunc then
        gg.alert("预览失败：\n"..err)
        return
    end

    callAsyncTask(function()
        local success, view = pcall(tempFunc)
        if success and view then
            gg.showAlert(view)
        else
            gg.alert("预览失败：\n"..tostring(view))
        end
    end)
end

--[[ 文件操作 ]]--
function UIEditor:generateAndSaveCode()
    local fileName = gg.prompt({"输入保存文件名"}, {self.config.defaultFile}, {"text"})[1]
    if not fileName then return end
    
    local fullPath = self.config.outputPath..fileName
    local code = self:generateCode()
    
    if file.write(fullPath, code) then
        gg.toast("保存成功："..fullPath, false)
        return true
    else
        gg.alert("保存失败，请检查路径权限")
        return false
    end
end

-- 核心方法：生成默认属性
function UIEditor:getDefaultProperties(propertiesDef)
    local defaults = {}
    for propName, propDef in pairs(propertiesDef) do
        if propDef.default ~= nil then
            defaults[propName] = propDef.default
        else
            -- 根据类型生成默认值
            if propDef.type == "choice" then
                defaults[propName] = propDef.options[1]
            elseif propDef.type == "multi" then
                defaults[propName] = table.concat(propDef.options, "|")
            elseif propDef.type == "number" then
                defaults[propName] = 0
            elseif propDef.type == "boolean" then
                defaults[propName] = false
            else
                defaults[propName] = ""
            end
        end
    end
    return defaults
end

function UIEditor:start()
    self:initWorkspace()
    self:showMainMenu()
end
function UIEditor:createNewLayout()
    local layoutTypes = {}
    for _, layout in ipairs(self._CONTROLS.layouts) do
        table.insert(layoutTypes, layout.icon.." "..layout.name)
    end

    local choice = gg.choice(layoutTypes, nil, "选择布局类型")
    if choice then
        local layoutDef = self._CONTROLS.layouts[choice]
        self.currentLayout = {
            type = layoutDef.type,
            children = {},
            properties = self:getDefaultProperties(layoutDef.properties),
            metadata = {
                created = os.date("%Y-%m-%d %H:%M:%S"),
                modified = os.date("%Y-%m-%d %H:%M:%S")
            }
        }
        gg.toast(layoutDef.name.."创建成功")
    end
end

function UIEditor:addComponent()
    if not self.currentLayout then
        gg.alert("请先创建布局")
        return
    end

    local widgetList = {}
    for _, widget in ipairs(self._CONTROLS.widgets) do
        table.insert(widgetList, widget.icon.." "..widget.name)
    end

    local choice = gg.choice(widgetList, nil, "添加组件")
    if choice then
        local widgetDef = self._CONTROLS.widgets[choice]
        local newComponent = {
            type = widgetDef.type,
            properties = self:getDefaultProperties(widgetDef.properties),
            metadata = {
                position = #self.currentLayout.children + 1,
                added = os.date("%Y-%m-%d %H:%M:%S")
            }
        }
        self:editComponentProperties(newComponent, widgetDef.properties)
        table.insert(self.currentLayout.children, newComponent)
        gg.toast(widgetDef.name.."添加成功")
    end
end

function UIEditor:editComponentProperties(component, propertiesDef)
    while true do
        local propNames = {}
        for name, _ in pairs(propertiesDef) do
            table.insert(propNames, name)
        end
        table.insert(propNames, "返回")

        local choice = gg.choice(propNames, nil, "编辑属性 - "..component.type)
        if not choice or propNames[choice] == "返回" then
            break
        end

        local propName = propNames[choice]
        local propDef = propertiesDef[propName]
        local currentValue = component.properties[propName]

        if propDef.type == "choice" then
            local newChoice = gg.choice(propDef.options, nil, "选择"..propName)
            if newChoice then
                component.properties[propName] = propDef.options[newChoice]
            end
        elseif propDef.type == "multi" then
            local choices = gg.multiChoice(propDef.options, nil, "选择"..propName)
            if choices then
                local selected = {}
                for i, v in ipairs(choices) do
                    if v then table.insert(selected, propDef.options[i]) end
                end
                component.properties[propName] = table.concat(selected, "|")
            end
        elseif propDef.type == "boolean" then
            component.properties[propName] = not component.properties[propName]
            gg.toast(propName.."设置为："..tostring(component.properties[propName]))
        else
            local inputType = "text"
            if propDef.type == "number" then inputType = "number" end
            local result = gg.prompt({"输入"..propName}, {tostring(currentValue)}, {inputType})
            if result then
                component.properties[propName] = propDef.type == "number" and tonumber(result[1]) or result[1]
            end
        end
    end
end

function UIEditor:generateCode()
    if not self.currentLayout then
        gg.alert("请先创建布局")
        return
    end

    local code = {
        "local luajava = require('luajava')",
"local floatingWindowManager = require('floatingWindowManager')",

"floatingWindowManager:init()",

"floatingWindowManager:newWindow('Yunzhu编辑器', {",
	"onCreate = function(floatingWindow)",
		"floatingWindow:addView(YUNZHU)",
	"end",
"})",

        "    YUNZHU= luajava.loadlayout({",
    }

    -- 生成布局属性
    table.insert(code, "        "..self.currentLayout.type..",")
    for prop, value in pairs(self.currentLayout.properties) do
        table.insert(code, self:_formatProperty(prop, value, 8))
    end

    -- 生成子组件
    for _, child in ipairs(self.currentLayout.children) do
        table.insert(code, "        {")
        table.insert(code, "            "..child.type..",")
        for prop, value in pairs(child.properties) do
            table.insert(code, self:_formatProperty(prop, value, 12))
        end
        table.insert(code, "        },")
    end

    table.insert(code, "    }, nil, context)")
    table.insert(code, "floatingWindowManager:run()")

    return table.concat(code, "\n")
end

function UIEditor:_formatProperty(prop, value, indent)
    local spaces = string.rep(" ", indent)
    if prop == "onClick" then
        return spaces..string.format('onClick = %s,', value)
    elseif prop == "background" then
        if value:match("^#") then
            return spaces..string.format('background = "%s",', value)
        else
            return spaces..string.format('background = luajava.getDrawable("%s"),', value)
        end
    elseif prop == "textColor" then
        return spaces..string.format('textColor = "%s",', value)
    else
        return spaces..string.format('%s = "%s",', prop, tostring(value))
    end
end

function UIEditor:previewUI()
    local code = self:generateCode()
    if not code then return end

    local tempFunc, err = load(code)
    if not tempFunc then
        gg.alert("预览失败：\n"..err)
        return
    end

    callAsyncTask(function()
        local view = tempFunc()
        gg.showAlert(view)
    end)
end

function UIEditor:save()
    local filename = gg.prompt({"输入保存文件名"}, {self.config.defaultFile}, {"text"})[1]
    if not filename then return end

    local path = self.config.outputPath..filename
    local code = self:generateCode()
    
    if file.write(path, code) then
        gg.toast("保存成功："..path)
        return true
    else
        gg.alert("保存失败，请检查路径权限")
        return false
    end
end


<?xml version="1.0" encoding="utf-8"?>
<android.fix.TabHost xmlns:android="http://schemas.android.com/apk/res/android" android:orientation="vertical" android:background="#c0000000" android:layout_width="match_parent" android:layout_height="match_parent">
    <android.fix.LinearLayout android:orientation="vertical" android:layout_width="match_parent" android:layout_height="match_parent">
        <android.fix.LinearLayout android:id="@+id/tabs" android:layout_width="match_parent" android:layout_height="wrap_content">
            <android.fix.FrameLayout android:layout_gravity="bottom" android:layout_width="48dp" android:layout_height="48dp" android:layout_weight="0">
                <android.fix.ImageButtonView android:id="@+id/app_icon" android:layout_width="48dp" android:layout_height="48dp" android:src="@drawable/ic_gg_48dp"/>
                <android.fix.ImageView android:id="@+id/small_icon" android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_gg_48dp"/>
            </android.fix.FrameLayout>
            <android.fix.TabWidget android:layout_gravity="bottom" android:id="@android:id/tabs" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
            <android.fix.LinearLayout android:visibility="gone" android:layout_width="wrap_content" android:layout_height="wrap_content">
                <android.fix.FrameLayout android:layout_gravity="center" android:id="@+id/config_tab" android:layout_width="wrap_content" android:layout_height="wrap_content" android:minHeight="48dp">
                    <android.fix.ImageView android:layout_gravity="center" android:id="@+id/config_tab_icon" android:padding="12dp" android:layout_width="48dp" android:layout_height="48dp" android:src="@drawable/ic_tune_white_24dp"/>
                </android.fix.FrameLayout>
                <android.fix.FrameLayout android:layout_gravity="center" android:id="@+id/search_tab" android:layout_width="wrap_content" android:layout_height="wrap_content" android:minHeight="48dp">
                    <android.fix.ImageView android:layout_gravity="center" android:id="@+id/search_tab_icon" android:padding="12dp" android:layout_width="48dp" android:layout_height="48dp" android:src="@drawable/ic_magnify_white_24dp"/>
                    <android.fix.TextView android:textAppearance="@style/SmallText" android:textColor="#ffffff" android:gravity="center" android:layout_gravity="top|right" android:id="@+id/search_tab_counter" android:background="@drawable/counter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="21"/>
                </android.fix.FrameLayout>
                <android.fix.FrameLayout android:layout_gravity="center" android:id="@+id/saved_tab" android:layout_width="wrap_content" android:layout_height="wrap_content" android:minHeight="48dp">
                    <android.fix.ImageView android:layout_gravity="center" android:id="@+id/saved_tab_icon" android:padding="12dp" android:layout_width="48dp" android:layout_height="48dp" android:src="@drawable/ic_content_save_white_24dp"/>
                    <android.fix.TextView android:textAppearance="@style/SmallText" android:textColor="#ffffff" android:gravity="center" android:layout_gravity="top|right" android:id="@+id/saved_tab_counter" android:background="@drawable/counter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="74"/>
                </android.fix.FrameLayout>
                <android.fix.FrameLayout android:layout_gravity="center" android:id="@+id/memory_tab" android:layout_width="wrap_content" android:layout_height="wrap_content">
                    <android.fix.ImageView android:layout_gravity="center" android:id="@+id/memory_tab_icon" android:padding="12dp" android:layout_width="48dp" android:layout_height="48dp" android:src="@drawable/ic_format_list_bulleted_white_24dp"/>
                </android.fix.FrameLayout>
            </android.fix.LinearLayout>
            <android.fix.ImageButtonView android:layout_gravity="center" android:id="@+id/menu_btn_land" android:padding="12dp" android:layout_width="48dp" android:layout_height="48dp" android:src="@drawable/ic_menu_white_24dp" android:layout_weight="0"/>
            <android.fix.ImageButtonView android:layout_gravity="center" android:id="@+id/back_btn" android:padding="12dp" android:layout_width="48dp" android:layout_height="48dp" android:src="@drawable/ic_close_white_24dp" android:layout_weight="0"/>
        </android.fix.LinearLayout>
        <android.fix.LinearLayout android:id="@+id/info_row" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_weight="0">
            <android.fix.ImageButton android:layout_gravity="center_vertical" android:id="@+id/process_pause" android:layout_width="32dp" android:layout_height="26dp" android:src="@drawable/ic_pause_white_18dp" android:minWidth="0dp" android:minHeight="0dp" android:layout_weight="0"/>
            <android.fix.TextButtonView android:textAppearance="@style/SmallText" android:gravity="center_vertical" android:layout_gravity="center_vertical" android:id="@+id/app_name" android:layout_width="0dp" android:layout_height="match_parent" android:layout_marginRight="6dp" android:text="@string/failed_run_daemon" android:layout_weight="10"/>
            <android.fix.LinearLayout android:layout_gravity="center_vertical" android:id="@+id/info_mem" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="10">
                <android.fix.TextButtonView android:textAppearance="@style/SmallText" android:gravity="center_vertical" android:layout_gravity="center_vertical" android:id="@+id/filter" android:layout_width="0dp" android:layout_height="match_parent" android:layout_marginRight="6dp" android:text="@string/no_filter" android:layout_weight="10"/>
                <android.fix.TextButtonView android:textAppearance="@style/SmallText" android:gravity="center_vertical" android:layout_gravity="center_vertical" android:id="@+id/value_format" android:layout_width="wrap_content" android:layout_height="match_parent" android:text="h,D,F" android:layout_weight="0"/>
            </android.fix.LinearLayout>
            <android.fix.LinearLayout android:layout_gravity="center_vertical" android:id="@+id/info_cnt" android:layout_width="wrap_content" android:layout_height="wrap_content">
                <android.fix.ProgressBar android:layout_gravity="center_vertical" android:id="@+id/count_wait" android:layout_width="26dp" android:layout_height="26dp" style="?android:attr/progressBarStyleSmall"/>
                <android.fix.TextButtonView android:textAppearance="@style/SmallText" android:gravity="center_vertical" android:layout_gravity="center_vertical" android:id="@+id/found_count" android:layout_width="wrap_content" android:layout_height="match_parent" android:text="(0)" android:layout_weight="0"/>
            </android.fix.LinearLayout>
            <android.fix.TextButtonView android:textAppearance="@style/SmallText" android:gravity="center_vertical" android:layout_gravity="center_vertical" android:id="@+id/saved_format" android:layout_width="wrap_content" android:layout_height="match_parent" android:text="h,D,F" android:layout_weight="0"/>
            <android.fix.ImageButton android:layout_gravity="center_vertical" android:id="@+id/menu_btn" android:layout_width="32dp" android:layout_height="26dp" android:src="@drawable/ic_menu_white_18dp" android:minWidth="0dp" android:minHeight="0dp"/>
            <android.fix.ImageButton android:layout_gravity="center_vertical" android:id="@+id/list_refresh" android:layout_width="32dp" android:layout_height="26dp" android:src="@drawable/ic_refresh_white_18dp" android:minWidth="0dp" android:minHeight="0dp" android:layout_weight="0"/>
        </android.fix.LinearLayout>
        <View android:background="#c0ffffff" android:layout_width="match_parent" android:layout_height="1dp"/>
        <android.fix.LinearLayout android:orientation="vertical" android:id="@+id/toolbar_row" android:layout_width="match_parent" android:layout_height="wrap_content">
            <android.fix.LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:baselineAligned="false">
                <android.fix.WrapLayout android:layout_gravity="center_vertical" android:id="@+id/search_toolbar" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"/>
                <android.fix.WrapLayout android:layout_gravity="center_vertical" android:id="@+id/saved_toolbar" android:visibility="gone" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"/>
                <android.fix.WrapLayout android:layout_gravity="center_vertical" android:id="@+id/memory_toolbar" android:visibility="gone" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"/>
                <android.fix.ImageButtonView android:layout_gravity="center_vertical" android:id="@+id/more_btn" android:padding="12dp" android:layout_width="45dp" android:layout_height="48dp" android:src="@drawable/ic_menu_white_24dp" android:layout_weight="0"/>
            </android.fix.LinearLayout>
            <View android:background="#c0ffffff" android:layout_width="match_parent" android:layout_height="1dp"/>
        </android.fix.LinearLayout>
        <android.fix.FrameLayout android:id="@android:id/tabcontent" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
            <android.fix.LinearLayout android:orientation="vertical" android:id="@+id/search_page" android:layout_width="match_parent" android:layout_height="match_parent">
                <android.fix.ListView android:id="@+id/addr_list" android:visibility="gone" android:layout_width="match_parent" android:layout_height="wrap_content"/>
                <android.fix.ScrollView android:id="@+id/nothing_found_view" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_weight="1">
                    <android.fix.TextView android:textAppearance="@style/MediumText" android:id="@+id/nothing_found_text" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/search_hint"/>
                </android.fix.ScrollView>
            </android.fix.LinearLayout>
            <android.fix.LinearLayout android:orientation="vertical" android:id="@+id/memory_editor_page" android:layout_width="match_parent" android:layout_height="match_parent">
                <android.fix.ListView android:id="@+id/mem_listview" android:layout_width="match_parent" android:layout_height="match_parent" android:fastScrollEnabled="true"/>
            </android.fix.LinearLayout>
            <android.fix.LinearLayout android:id="@+id/config_page" android:background="#000000" android:layout_width="match_parent" android:layout_height="match_parent">
                <android.fix.ListView android:id="@+id/config_list" android:layout_width="match_parent" android:layout_height="wrap_content"/>
            </android.fix.LinearLayout>
            <android.fix.LinearLayout android:orientation="vertical" android:id="@+id/saved_page" android:layout_width="match_parent" android:layout_height="match_parent">
                <android.fix.ListView android:id="@+id/saved_list" android:layout_width="match_parent" android:layout_height="wrap_content"/>
                <android.fix.ScrollView android:id="@+id/empty_list_view" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_weight="1">
                    <android.fix.TextView android:textAppearance="@style/MediumText" android:id="@+id/empty_list_text" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/empty_list"/>
                </android.fix.ScrollView>
            </android.fix.LinearLayout>
        </android.fix.FrameLayout>
        <android.fix.TextButtonView android:textAppearance="@style/SmallText" android:gravity="center" android:id="@+id/status_bar" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginRight="60dp" android:text="8.40.0  +  Ch,Jh,Ca,Cd,Cb,A,S,O" android:layout_weight="0"/>
    </android.fix.LinearLayout>
</android.fix.TabHost>

<?xml version="1.0" encoding="utf-8"?>
<android.fix.ScrollView xmlns:android="http://schemas.android.com/apk/res/android" android:paddingLeft="6dp" android:paddingRight="6dp" android:layout_width="match_parent" android:layout_height="match_parent">
    <android.fix.LinearLayout android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content">
        <android.fix.TextView android:textAppearance="@style/SmallText" android:layout_gravity="center_vertical" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/only_memory"/>
        <android.fix.TextView android:textAppearance="@style/SmallText" android:layout_gravity="center_vertical" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/from_range"/>
        <android.fix.LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content">
            <android.ext.EditText android:layout_gravity="center_vertical" android:id="@+id/memory_from" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:imeOptions="actionNext"/>
            <android.ext.RegionList android:layout_gravity="center_vertical" android:id="@+id/region_from" android:layout_width="48dp" android:layout_height="48dp"/>
        </android.fix.LinearLayout>
        <android.fix.TextView android:textAppearance="@style/SmallText" android:layout_gravity="center_vertical" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/to_range"/>
        <android.fix.LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content">
            <android.ext.EditText android:layout_gravity="center_vertical" android:id="@+id/memory_to" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:imeOptions="actionNext"/>
            <android.ext.RegionList android:layout_gravity="center_vertical" android:id="@+id/region_to" android:layout_width="48dp" android:layout_height="48dp"/>
        </android.fix.LinearLayout>
        <android.fix.TextView android:textAppearance="@style/SmallText" android:layout_gravity="center_vertical" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/path"/>
        <android.fix.LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content">
            <android.ext.EditTextPath android:layout_gravity="center_vertical" android:id="@+id/path" android:layout_width="0dp" android:layout_height="wrap_content" android:hint="@string/sdcard" android:maxLength="120" android:layout_weight="1" android:inputType="text" android:imeOptions="actionDone"/>
            <android.ext.PathSelector android:textSize="@dimen/button_text_size" android:layout_gravity="center" android:id="@+id/path_selector" android:layout_width="48dp" android:layout_height="48dp" android:textAllCaps="false"/>
        </android.fix.LinearLayout>
        <android.fix.Button android:textSize="@dimen/button_text_size" android:id="@+id/typical_values" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/typical_values" android:textAllCaps="false"/>
        <android.fix.CheckBox android:textAppearance="@style/SmallText" android:id="@+id/skip_system_libs" android:layout_width="wrap_content" android:layout_height="wrap_content" android:checked="true" android:text="@string/skip_system_libs"/>
    </android.fix.LinearLayout>
</android.fix.ScrollView>

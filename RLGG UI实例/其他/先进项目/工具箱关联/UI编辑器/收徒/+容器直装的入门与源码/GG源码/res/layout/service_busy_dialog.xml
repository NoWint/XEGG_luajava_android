<?xml version="1.0" encoding="utf-8"?>
<android.fix.LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" android:orientation="vertical" android:paddingLeft="5dp" android:paddingRight="5dp" android:paddingBottom="5dp" android:layout_width="match_parent" android:layout_height="wrap_content" android:keepScreenOn="true">
    <android.fix.TextView android:textAppearance="@style/SmallText" android:gravity="center_vertical" android:layout_gravity="center" android:id="@+id/message" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/loading"/>
    <android.fix.LinearLayout android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="15dp" android:layout_marginBottom="15dp">
        <android.fix.LinearLayout android:layout_gravity="center" android:orientation="horizontal" android:layout_width="wrap_content" android:layout_height="wrap_content">
            <ProgressBar android:layout_gravity="center" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginRight="10dp" style="?android:attr/progressBarStyleSmall"/>
            <android.fix.TextView android:textAppearance="@style/MediumText" android:id="@+id/progress_bar_text" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </android.fix.LinearLayout>
        <android.fix.ProgressBar android:id="@+id/progress_bar" android:layout_width="match_parent" android:layout_height="wrap_content" android:max="100" android:progress="0" android:indeterminate="true" style="?android:attr/progressBarStyleHorizontal"/>
    </android.fix.LinearLayout>
    <android.fix.LinearLayout android:orientation="vertical" android:id="@+id/stage_layout" android:visibility="gone" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="15dp">
        <android.fix.TextView android:textAppearance="@style/MediumText" android:gravity="center" android:id="@+id/progress_bar_stage_text" android:layout_width="match_parent" android:layout_height="wrap_content"/>
        <android.fix.ProgressBar android:id="@+id/progress_bar_stage" android:layout_width="match_parent" android:layout_height="wrap_content" android:max="100" android:progress="0" style="?android:attr/progressBarStyleHorizontal"/>
    </android.fix.LinearLayout>
    <android.fix.TextView android:textAppearance="@style/SmallText" android:layout_gravity="center_vertical" android:id="@+id/found_count" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    <android.fix.TextView android:textAppearance="@style/SmallText" android:layout_gravity="center_vertical" android:id="@+id/time" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    <android.fix.Button android:textAppearance="@style/SmallText" android:layout_gravity="center_vertical" android:id="@+id/help_speed_up" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/help_speed_up_title"/>
</android.fix.LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<android.fix.LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" android:gravity="center_vertical" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_margin="0dp">
    <android.fix.ImageView android:layout_gravity="center_vertical" android:id="@+id/icon" android:padding="12dp" android:layout_width="48dp" android:layout_height="48dp" android:layout_margin="0dp" android:src="@drawable/ic_file_white_24dp"/>
    <android.fix.LinearLayout android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content">
        <android.fix.TextView android:textAppearance="@style/SmallText" android:textStyle="bold" android:gravity="left" android:id="@+id/name" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="some_name"/>
        <android.fix.LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content">
            <android.fix.TextView android:textAppearance="@style/SmallText" android:gravity="left" android:layout_gravity="left" android:id="@+id/date" android:layout_width="0dp" android:layout_height="wrap_content" android:text="2000-12-31 17:34:55" android:layout_weight="1"/>
            <android.fix.TextView android:textAppearance="@style/SmallText" android:gravity="right" android:layout_gravity="right" android:id="@+id/size" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="12.34 MB"/>
        </android.fix.LinearLayout>
    </android.fix.LinearLayout>
</android.fix.LinearLayout>

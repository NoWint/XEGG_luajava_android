<?xml version="1.0" encoding="utf-8"?>
<android.fix.LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" android:orientation="vertical" android:paddingLeft="20dp" android:paddingRight="20dp" android:paddingBottom="10dp" android:layout_width="match_parent" android:layout_height="wrap_content">
    <android.fix.LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content">
        <android.fix.TextView android:textAppearance="@style/MediumText" android:layout_gravity="center_vertical" android:id="@+id/config_icon_text" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/config_icon_text" android:layout_weight="1"/>
        <android.fix.ImageView android:layout_gravity="center" android:id="@+id/config_icon_example" android:layout_width="wrap_content" android:layout_height="wrap_content" android:src="@drawable/ic_gg_48dp"/>
    </android.fix.LinearLayout>
    <android.fix.SeekBar android:id="@+id/transparency" android:layout_width="match_parent" android:layout_height="wrap_content" android:max="10"/>
    <android.fix.SeekBar android:id="@+id/hide" android:layout_width="match_parent" android:layout_height="wrap_content" android:max="31"/>
    <android.fix.SeekBar android:id="@+id/size" android:layout_width="match_parent" android:layout_height="wrap_content" android:max="1"/>
</android.fix.LinearLayout>

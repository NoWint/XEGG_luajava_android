<?xml version="1.0" encoding="utf-8"?>
<android.fix.LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" android:orientation="vertical" android:layout_width="match_parent" android:layout_height="match_parent">
    <android.fix.LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content">
        <android.fix.ImageButtonView android:layout_gravity="center_vertical" android:id="@+id/add" android:padding="12dp" android:layout_width="48dp" android:layout_height="48dp" android:layout_margin="0dp" android:src="@drawable/ic_folder_plus_white_24dp"/>
        <android.fix.ImageButtonView android:layout_gravity="center_vertical" android:id="@+id/sort" android:padding="12dp" android:layout_width="48dp" android:layout_height="48dp" android:layout_margin="0dp" android:src="@drawable/ic_sort_name_white_24dp"/>
        <android.fix.TextView android:textAppearance="@style/SmallText" android:layout_gravity="center_vertical" android:id="@+id/path" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="/please/do/not.remove.this/if/you/do/not/want/pro/version" android:layout_weight="1"/>
        <android.fix.ImageButtonView android:layout_gravity="center_vertical" android:id="@+id/up" android:padding="12dp" android:layout_width="48dp" android:layout_height="48dp" android:layout_margin="0dp" android:src="@drawable/ic_folder_upload_white_24dp"/>
    </android.fix.LinearLayout>
    <android.fix.LinearLayout android:orientation="vertical" android:paddingRight="3dp" android:layout_width="match_parent" android:layout_height="match_parent" android:minWidth="10000dp" android:minHeight="10000dp">
        <android.fix.TextView android:textAppearance="@style/MediumText" android:gravity="center" android:layout_gravity="center" android:id="@+id/failed" android:layout_width="match_parent" android:layout_height="match_parent" android:text="@string/failed_list_dir"/>
        <android.fix.ListView android:id="@+id/files" android:layout_width="match_parent" android:layout_height="match_parent" android:fastScrollEnabled="true"/>
    </android.fix.LinearLayout>
</android.fix.LinearLayout>

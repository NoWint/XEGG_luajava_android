<?xml version="1.0" encoding="utf-8"?>
<android.fix.LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" android:orientation="vertical" android:paddingLeft="6dp" android:paddingRight="6dp" android:layout_width="match_parent" android:layout_height="wrap_content">
    <android.fix.LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content">
        <android.fix.TextView android:layout_gravity="center_vertical" android:id="@+id/addr" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/address"/>
        <android.ext.EditText android:layout_gravity="center_vertical" android:id="@+id/mem_edit_addr" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:inputType="text" android:imeOptions="actionGo" android:textAllCaps="true"/>
        <android.ext.RegionList android:layout_gravity="center_vertical" android:id="@+id/region_from" android:layout_width="48dp" android:layout_height="48dp"/>
    </android.fix.LinearLayout>
    <android.fix.WrapLayout android:layout_width="match_parent" android:layout_height="wrap_content">
        <android.fix.Button android:textAppearance="@style/SmallText" android:layout_gravity="center_vertical" android:id="@+id/history" android:layout_width="wrap_content" android:layout_height="wrap_content" android:minWidth="48dp" android:text="@string/history"/>
        <android.fix.Button android:textAppearance="@style/SmallText" android:layout_gravity="center_vertical" android:id="@+id/cd" android:layout_width="wrap_content" android:layout_height="wrap_content" android:minWidth="48dp" android:text="Cd"/>
        <android.fix.Button android:textAppearance="@style/SmallText" android:layout_gravity="center_vertical" android:id="@+id/cb" android:layout_width="wrap_content" android:layout_height="wrap_content" android:minWidth="48dp" android:text="Cb"/>
        <android.fix.Button android:textAppearance="@style/SmallText" android:layout_gravity="center_vertical" android:id="@+id/ps" android:layout_width="wrap_content" android:layout_height="wrap_content" android:minWidth="48dp" android:text="PS"/>
        <android.fix.Button android:textAppearance="@style/SmallText" android:layout_gravity="center_vertical" android:id="@+id/xa" android:layout_width="wrap_content" android:layout_height="wrap_content" android:minWidth="48dp" android:text="Xa"/>
    </android.fix.WrapLayout>
</android.fix.LinearLayout>

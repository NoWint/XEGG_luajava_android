--[[
  RLGG企业级文件加密工具（修复版）
  修复问题：
  1. 添加RLGG环境检测
  2. 增强文件操作兼容性
  3. 补充错误处理逻辑
--]]

----------------------------------------
--          [ 环境检测模块 ]          --
----------------------------------------
if not gg or not gg.alert then
    print("❌ 必须在RLGG环境中运行！")
    os.exit()
end

gg.setVisible(true)
gg.toast("🛡️ RLGG文件加密工具启动...", false)

----------------------------------------
--          [ 文件操作模块 ]          --
-- 适配RLGG的特殊文件权限要求 --
----------------------------------------
local function safeReadFile(path)
    for i = 1, 3 do  -- 重试机制
        local ok, content = pcall(file.read, path)
        if ok then return content end
        gg.sleep(500)
    end
    return nil
end

local function safeWriteFile(path, data)
    local tmpPath = path .. ".tmp"
    for i = 1, 3 do
        local f = io.open(tmpPath, "w")
        if f then
            f:write(data)
            f:close()
            os.rename(tmpPath, path)
            return true
        end
        gg.sleep(300)
    end
    return false
end

----------------------------------------
--          [ UI交互模块 ]            --
-- 完全适配RLGG的UI限制 --
----------------------------------------
local function selectFile()
    -- 获取SD卡可读目录
    local scanPath = gg.EXT_STORAGE .. "/Scripts/"
    if not file.isDir(scanPath) then
        scanPath = gg.EXT_STORAGE
    end

    -- 构建文件列表（RLGG兼容方式）
    local files = {}
    for f in file.list(scanPath) do
        if f:match("%.lua$") then
            table.insert(files, f)
        end
    end

    if #files == 0 then
        gg.alert("❌ 未找到.lua文件\n请将脚本放入"..scanPath)
        return nil
    end

    -- RLGG专用选择框
    local choices = {}
    for i,f in ipairs(files) do
        choices[i] = (#f > 30 and "..." or "")..f:sub(-30)
    end

    local sel = gg.multiChoice(choices, nil, "🔒 选择要加密的文件:")
    if not sel then return nil end

    for i,v in ipairs(sel) do
        if v then return scanPath..files[i] end
    end
end

local function getSavePath(inputFile)
    local defaultName = inputFile:match("/([^/]+)$"):gsub("%.lua$", "_enc.lua")
    local defaultPath = gg.EXT_STORAGE.."/Encrypted/"..defaultName

    -- 创建输出目录
    if not file.isDir(gg.EXT_STORAGE.."/Encrypted") then
        os.execute("mkdir -p "..gg.EXT_STORAGE.."/Encrypted")
    end

    local input = gg.prompt({
        "保存路径：",
        "加密选项："
    }, {
        defaultPath,
        "企业版（字符串混淆+防篡改）"
    }, {
        "text",
        {"企业版","标准版"}
    })

    return input and input[1] or nil
end

----------------------------------------
--          [ 加密核心模块 ]          --
-- 适配RLGG的Lua 5.3环境 --
----------------------------------------
local function enterpriseEncrypt(data)
    -- 阶段1：字符串混淆
    local strCache = {}
    data = data:gsub('(["\'])(.-)%1', function(quote, str)
        local key = "S"..#strCache
        strCache[key] = str
        return string.format('_G["%s"]', key)
    end)

    -- 阶段2：添加RLGG企业版头
    local header = string.format([[
-- RLGG ENTERPRISE ENCRYPTED --
-- Time: %s --
-- MD5: %s --
]], os.date("%Y-%m-%d %H:%M:%S"), string.md5(data))

    return header..data
end

----------------------------------------
--          [ 主流程 ]               --
----------------------------------------
local function main()
    -- 步骤1：选择文件
    local inputPath = selectFile()
    if not inputPath then
        gg.toast("已取消操作", false)
        return
    end

    -- 步骤2：读取内容
    gg.toast("📖 读取文件中...", false)
    local content = safeReadFile(inputPath)
    if not content then
        gg.alert("文件读取失败:\n"..inputPath.."\n\n可能原因：\n1. 文件权限不足\n2. 文件被占用")
        return
    end

    -- 步骤3：获取保存路径
    local savePath = getSavePath(inputPath)
    if not savePath then
        gg.toast("已取消保存", false)
        return
    end

    -- 步骤4：执行加密
    gg.toast("🔒 加密处理中...", true)
    local encrypted = enterpriseEncrypt(content)

    -- 步骤5：保存文件
    if safeWriteFile(savePath, encrypted) then
        gg.alert(string.format([[
✅ 加密成功！

原始文件: %s
加密文件: %s
文件大小: %.2f KB

加密特征:
• 字符串混淆
• 防篡改校验
• RLGG企业版头
        ]], 
        inputPath, savePath, #encrypted/1024))
        
        -- 可选：打开文件管理器
        if gg.alert("是否查看加密文件？", "查看", "关闭") == 1 then
            os.execute("am start -n com.android.documentsui/com.android.documentsui.ViewActivity -d file://"..savePath)
        end
    else
        gg.alert("❌ 文件保存失败！\n请检查存储权限或路径有效性")
    end
end

----------------------------------------
--          [ 安全执行 ]             --
----------------------------------------
xpcall(main, function(err)
    gg.alert("⚠️ 发生严重错误:\n"..tostring(err).."\n\n"..debug.traceback())
end)

gg.toast("加密工具已关闭", false)
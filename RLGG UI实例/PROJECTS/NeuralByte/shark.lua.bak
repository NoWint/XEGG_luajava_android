local dpi=context:getResources():getDisplayMetrics().densityDpi
function getpx(x)
	if type(x)=='string' then
		if string.find(x,'dp') then 
			x=string.gsub(x,'dp','')
			x=tonumber(x)
		end
		return x*(dpi/160)
	else
		return x
	end
end
function getdp(x)
	if type(x)=='number' then
		return x/(dpi/160)..'dp'
	else
		return x
	end
end

function getdp(x)
	if type(x)=='number' then
		return x/(dpi/160)..'dp'
	else
		return x
	end
end


			{android.R.attr.state_pressed},
			{-android.R.attr.state_pressed},
		}, {
			0xFFFFFFFF,
			0xFFFFFFFF,
			0xFFFFFFFF
		})		
local RadTint=ColorStateList({
			{android.R.attr.state_checked},

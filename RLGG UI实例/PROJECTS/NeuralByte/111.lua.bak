local gg = require('gg')local luajava = require('luajava')local android = import('android.*')Yunzhu = {}resource = {	{'sensor.dex','https://xg-cloudreve.cloud-k1.riyx.cn/f/PQNSJ/sensor.dex'}}function panduan(rec) fille,err = io.open(rec) if fille == nil then return false else return true end endfunction checkimg(tmp,value)if panduan("/sdcard/於柒/图片/"..tmp[1]) ~= true thenfile.download(tmp[2],"/sdcard/於柒/图片/"..tmp[1])endendfor i=1,#resource docheckimg(resource[i],i)enddex.loadfile("/sdcard/於柒/图片/sensor.dex")import"com.changan.CACore.*"import "android.content.res.ColorStateList"dex.loadfile("/storage/emulated/0/hiddenapibypass.dex")import("org.lsposed.hiddenapibypass.*")HiddenApiBypass:addHiddenApiExemptions{""}context = app.contextwindow = context:getSystemService("window") -- 获取窗口管理器function getLayoutParams()	LayoutParams = WindowManager.LayoutParams	layoutParams = luajava.new(LayoutParams)	if (Build.VERSION.SDK_INT >= 26) then -- 设置悬浮窗方式		layoutParams.type = LayoutParams.TYPE_APPLICATION_OVERLAY		else		layoutParams.type = LayoutParams.TYPE_PHONE	end	layoutParams.format = PixelFormat.RGBA_8888 -- 设置背景	layoutParams.flags = LayoutParams.FLAG_NOT_FOCUSABLE -- 焦点设置Finish	layoutParams.gravity = Gravity.TOP|Gravity.LEFT -- 重力设置	layoutParams.width = LayoutParams.WRAP_CONTENT -- 布局宽度	layoutParams.height = LayoutParams.WRAP_CONTENT -- 布局高度	return layoutParamsendhanshu = function(v, event)	local Action = event:getAction()	if Action == MotionEvent.ACTION_DOWN then		isMove = false		RawX = event:getRawX()		RawY = event:getRawY()		x = mainLayoutParams.x		y = mainLayoutParams.y		elseif Action == MotionEvent.ACTION_MOVE then		isMove = true		mainLayoutParams.x = tonumber(x) + (event:getRawX() - RawX)		mainLayoutParams.y = tonumber(y) + (event:getRawY() - RawY)		window:updateViewLayout(floatWindow, mainLayoutParams)	endendfunction guid()seed = {	'e','1','2','3','4','5','6','7','8','9','a','b','c','d','e','f'}tb = {}for i = 1,32 dotable.insert(tb,seed[math.random(1,16)])endsid = table.concat(tb)return string.format('%s%s%s%s%s',	string.sub(sid,1,8),	string.sub(sid,10,12),	string.sub(sid,21,22))..string.format('%s%s%s%s%s',	string.sub(sid,1,6),	string.sub(sid,21,25))endsuofang = function(v, event)local Action = event:getAction()if Action == MotionEvent.ACTION_DOWN thenisMove = falseRawX = event:getRawX()RawY = event:getRawY()hx = mainLayoutParams.heighthy = mainLayoutParams.widthif hx == 0 or hx==-2 then hx =810 hy = 1150 endelseif Action == MotionEvent.ACTION_MOVE thenisMove = truemubx = tonumber(hx) + (event:getRawY() - RawY)if mubx >= 250 and mubx <= 11100 thenmainLayoutParams.height = mubxendmuby = tonumber(hy) + (event:getRawX() - RawX)if muby >= 250 and muby <= 24500 thenmainLayoutParams.width = mubyendif muby<=250 and mubx<=250 then muby=250 mubx=250--隐藏()return 0 endwindow:updateViewLayout(floatWindow, mainLayoutParams)endendfunction getVerticalBG(gtvb1,gtvb3,gtvb4,gtvb5)if not gtvb4 then gtvb4 = 0 gtvb5 = 0xff000000 endlocal jianbians = luajava.new(GradientDrawable)jianbians:setCornerRadius(gtvb3)jianbians:setGradientType(GradientDrawable.LINEAR_GRADIENT)jianbians:setColors(gtvb1)jianbians:setStroke(gtvb4,gtvb5)return jianbiansendlocal ViewGroupClass = luajava.bindClass("android.view.ViewGroup")local TextViewClass = luajava.bindClass("android.widget.TextView")local ImageViewClass = luajava.bindClass("android.widget.ImageView")local isswitch	if isswitch then		return false	end	sview={}Yunzhu.menu = function(sview)	isswitch = true	cebian = {		LinearLayout,		layout_width = "80dp",		layout_height = "match_parent",		gravity = "center",		orientation = "vertical",	}	for i=1,#stab do		cebian[#cebian+1] = {			TextView,			id = "jmt"..i,			text = stab[i],			gravity = "center",			layout_width = "80dp",			layout_height = "30dp",			layout_margin = "1dp",			textColor = 0xFFFFFFFF,			padding="4dp",			background=luajava.loadlayout{				GradientDrawable,				color=0x90474A6D,				cornerRadius=8			},			onClick = function()				切换(i)			end		}	end	cebian = {		ScrollView,		id = "cebian",		layout_height = "match_parent",		layout_width = "81dp",		layout_margin = "1dp",		gravity = "center",		background=luajava.loadlayout{			GradientDrawable,			color=0x30161616,			cornerRadius=5		},		cebian	}	mainlayout = {		LinearLayout,		id = "mainlayout",		layout_height = "match_parent",		layout_width = "match_parent",		gravity = "center",	}	for i=1,#sview do		_G["layout"..i] ={			LinearLayout,			id = "layout"..i,			layout_height = "match_parent",			layout_width = "match_parent",			orientation = "vertical",		}		lay = _G["layout"..i]		for k=1,#sview[i] do			lay[#lay+1] = sview[i][k]		end		_G["layoutm"..i] = {			ScrollView,			layout_height = "match_parent",			layout_width = "match_parent",			id = "layoutm"..i,			_G["layout"..i]		}	end	for i=1,#sview do		mainlayout[#mainlayout+1] = _G["layoutm"..i]	end	floatWindow = {		LinearLayout,		id = "motion",		elevation = "10dp",		onTouch = hanshu,		onClick = function() end,		layout_width = "match_parent",		orientation = "vertical",		layout_height = "wrap_content",		{			TextView,			text = " ▼ "..项目名称,			id = "title",			textSize = "15dp",			textColor = "#FFFFFF",			layout_width = "match_parent",			layout_height = "20dp",			gravity = "left",			background=luajava.loadlayout{				GradientDrawable,				color=0x906867AA,				cornerRadius=8			},			onClick = 隐藏,			onTouch = hanshu		},		{			FrameLayout,			id = "ckou",			layout_width="match_parent",			layout_height="match_parent",			{				LinearLayout,				layout_width = "match_parent",				layout_marginTop = "3dp",				layout_marginLeft = "2dp",				cebian,				mainlayout			},			{				TextView,				text = "◢",				textSize = "30dp",				textColor=0xff6867AA,				layout_width="30dp",				layout_height="30dp",				id="jiaobiao",				layout_gravity="right|bottom",				onClick=function() end,				onTouch=suofang			}		}	}	local function invoke()		local ok		local RawX, RawY, x, y		mainLayoutParams = getLayoutParams()		floatWindow = luajava.loadlayout(floatWindow)		local function invoke2()			block('start')			window:addView(floatWindow, mainLayoutParams)			motion:getLayoutParams().flags = LayoutParams.FLAG_NOT_FOCUSABLE			motion:getLayoutParams().height = 高度			motion:getLayoutParams().width = 宽度			UIheight = 高度			window:updateViewLayout(floatWindow, mainLayoutParams)			block('end')		end		local runnable = luajava.getRunnable(invoke2)		local handler = luajava.getHandler()		handler:post(runnable)		block('join')		local isMove	end	invoke(swib1,swib2)	gg.setVisible(false)	luajava.setFloatingWindowHide(true)	luajava.postMain(function()	luajava.post(function()	Background = luajava.loadlayout({GradientDrawable,color=0x66161616,cornerRadius=8})	--Background:setStroke(2,"0xFF161616")	view = motion.view	local viewRootImpl = view:getViewRootImpl()    local blurRoot = HiddenApiBypass:getDeclaredMethod(ViewRootImpl, "createBackgroundBlurDrawable", {})      blurRoot = blurRoot:invoke(viewRootImpl, {})      blurRoot:setBlurRadius(60)      blurRoot:setCornerRadius(8)      BackgroundDrawable = LayerDrawable({blurRoot,Background})      view:setBackgroundDrawable(BackgroundDrawable)      end)      end)endfunction 隐藏()luajava.runUiThread(function()if tonumber (tostring (ckou: getVisibility ())) == 8.0 then ckou:setVisibility(0)title:setText(" ▼ "..项目名称)motion:getLayoutParams().height = UIheightwindow:updateViewLayout(floatWindow, mainLayoutParams)elseckou:setVisibility(8)title:setText(" ▲ "..项目名称)motion:getLayoutParams().height = LayoutParams.WRAP_CONTENTwindow:updateViewLayout(floatWindow, mainLayoutParams)endend)endfunction 切换(x)当前ui = xluajava.runUiThread(function()for i=1,#stab do_G['layoutm'..i]:setVisibility(8)endend)_G['layoutm'..当前ui]:setVisibility(0)endlocal function exit()	tuichu = 1	luajava.setFloatingWindowHide(false)	tuic=true	luajava.post(function()		window:removeView(floatWindow)	end)endsetExitEvent(exit)Initialization = function()function Yunzhu.intcheck(name,func1,func2)  nid=name..string.randomUUID(true)  if not name then name="未设置" end  local swcDraw=ColorStateList({			{android.R.attr.state_checked},			{},		},	    {			0xff6867AA,			0x55DFDFDF		})local swcThumb=ColorStateList({			{android.R.attr.state_checked},			{android.R.attr.state_pressed},			{-android.R.attr.state_pressed},		}, {			0xFFFFFFFF,			0xFFFFFFFF,			0xFFFFFFFF		})  check={    LinearLayout,    layout_width='match_parent',    layout_height="42dp",    layout_weight=1,    layout_marginTop="1dp",    layout_marginBottom="1dp",    {			SwitchButton,			ThumbRadius = "90dp",			BackRadius = "90dp",			ThumbRangeRatio = '0.9dp',			ThumbMargin = RectF(5,5,5,5),			id=luajava.newId(nid),			__onFinish=function(v)			v:setThumbColor(swcThumb)			v:setBackColor(swcDraw)				luajava.setInterface(v, "setOnCheckedChangeListener", 					{onCheckedChanged=function(view,isc)						if isc then          luajava.newThread(function()            pcall(func1)          end):start()         else          luajava.newThread(function()            pcall(func2)          end):start()        end					end})			end,			layout_width = "45dp",			layout_height = "20dp",		},		{		TextView,		text = name,		layout_height = "20dp",		gravity = "center",		textColor = 0xFFFFFFFF,		}  }  return checkendfunction Yunzhu.check(cklist)  if #cklist==0 then return nil end  local rest={    LinearLayout,    layout_width='fill_parent',    layout_height="wrap_content",    layout_marginRight="4dp",    layout_marginLeft="4dp",    layout_marginTop="3.5dp",    layout_marginBottom="3.5dp",    gravity="center",    orientation="vertical",  }  for i=1,#cklist,2 do    local tempTable={LinearLayout,      layout_width='fill_parent',      layout_height="wrap_content",      gravity="left",      orientation="horizontal"    }    for j=0,1 do      if cklist[i + j] ~=nil then        local name=cklist[i + j][1]        local func1=cklist[i + j][2]        local func2=cklist[i + j][3]        if not name then name="未设置" end        rstt=Yunzhu.intcheck(name,func1,func2)        table.insert(tempTable,rstt)       else        table.insert(tempTable,{LinearLayout,          layout_width='match_parent',          layout_weight=1,})      end    end    table.insert(rest,tempTable)  end  return restendend项目名称 = "Imgui"stab = {	'绘制',	'追踪',	'其他'}高度 = 500宽度 = 900Initialization()import("android.widget.ListView")import("android.widget.ArrayAdapter")import("android.view.ViewGroup")import("android.widget.ListView")import("android.widget.ArrayAdapter")import("android.view.ViewGroup")function createControlsListViewInside(sviewData, tabNames)    if not sviewData or not tabNames then      --  return luajava.loudlayout({TextView,text="数据加载中...", textSize="14sp", textColor="#ffffff"})    end        -- 收集所有控件信息    local controlList = {}        for pageIndex, pageControls in ipairs(sviewData) do        local pageName = tabNames[pageIndex] or ("页面" .. pageIndex)                for controlIndex, control in ipairs(pageControls) do            local controlInfo = pageName .. " - 控件" .. controlIndex                        -- 根据控件类型添加更多信息            if type(control) == "table" then                if control.text then                    controlInfo = controlInfo .. " (文本: " .. tostring(control.text) .. ")"                elseif control.onClick then                    controlInfo = controlInfo .. " (按钮)"                end            end                        table.insert(controlList, controlInfo)        end    end        -- 创建适配器    local adapter = ArrayAdapter(context, android.R.layout.simple_list_item_1, controlList)        -- 创建 ListView    local listView = ListView(context)    listView:setAdapter(adapter)        -- 设置布局参数    local layoutParams = luajava.new(ViewGroup.LayoutParams,         ViewGroup.LayoutParams.MATCH_PARENT,         ViewGroup.LayoutParams.MATCH_PARENT)    listView:setLayoutParams(layoutParams)        -- 设置样式    listView:setBackgroundColor(0x33000000)        -- 设置点击事件    luajava.setInterface(listView, 'setOnItemClickListener', function(parent, view, position, id)        local selectedItem = controlList[position + 1]        gg.toast("选中: " .. selectedItem)    end)        return listViewendfunction createSimpleFunctionList()    local functions = {        "🎮 游戏功能",        "⚡ 性能优化",         "🎨 视觉设置",        "🔊 音频控制",        "🌐 网络设置",        "⚙️ 系统工具",        "📊 状态监控",        "🔧 高级设置"    }        local adapter = ArrayAdapter(context, android.R.layout.simple_list_item_1, functions)    local listView = ListView(context)    listView:setAdapter(adapter)        local layoutParams = luajava.new(ViewGroup.LayoutParams,         ViewGroup.LayoutParams.MATCH_PARENT,         ViewGroup.LayoutParams.MATCH_PARENT)    listView:setLayoutParams(layoutParams)        listView:setBackgroundColor(0x33000000)        luajava.setInterface(listView, 'setOnItemClickListener', function(parent, view, position, id)        local selected = functions[position + 1]                -- 根据选择执行不同操作        if selected == "🎮 游戏功能" then            gg.toast("切换到游戏功能页面")            切换(1)  -- 切换到第一个页面        elseif selected == "⚡ 性能优化" then            gg.toast("性能优化功能")        elseif selected == "🎨 视觉设置" then            gg.toast("视觉设置功能")        -- 可以添加更多功能...        end    end)        return listViewend	LV=luajava.loadlayout( {                LinearLayout,                layout_width = "match_parent",                layout_height = "match_parent",                orientation = "vertical",                padding = "10dp",                background = getVerticalBG({0x78000000,0x78000000},15),                {                    TextView,                    text = "🛠️ 控件列表",                    textSize = "16sp",                    textColor = "#ffffff",                    layout_marginBottom = "10dp",                    gravity = "center"                },                -- 直接在内部创建 ListView               createControlsListViewInside(sview, stab)           --   createSimpleFunctionList(),	            })--页面必须和菜单数一样多，不然报错Yunzhu.menu({	{	--createSimpleFunctionList(),			Yunzhu.check({      {        "例子",        function()        end,        function()        end        }, {        "例子",        function()        end,        function()        end        }, {        "测试1",        function()        end,        function()        end      },    }),	},	{	createSimpleFunctionList(),			},	{LV,	}})while true do	if tuichu==1 then 		break	endend
--[[
使用 windowManager 模块把组件(View)添加到悬浮窗操作只需要两步
--1.导入 windowManager 模块
local windowManager = require('windowManager')
--2.执行
windowManager:addView(你的组件)
--]]

local windowManager = require('windowManager')
local rootViewManager
local rootView

rootView = luajava.loadlayout({
    LinearLayout,
    layout_width = 'wrap_content',
    layout_height = 'wrap_content',
    padding = '20dp',
    orientation = 'vertical',
    backgroundColor = 0x00000000,
    {
        Button,
        text = '可以移动',
        onClick = function()
            rootViewManager:setMoveable(true)
        end
    },
    {
        Button,
        text = '禁止移动',
        onClick = function()
            rootViewManager:setMoveable(false)
        end
    },
    {
        Button,
        text = '隐藏3秒',
        onClick = function()
            rootViewManager:hide()

            luajava.startThread(function()
                local len = 3
                for i = 1, len do
                    gg.toast(len - (i - 1))
                    gg.sleep(1000)
                end
                rootViewManager:show()
            end)

        end
    },
    {
        Button,
        text = '退出悬浮窗',
        onClick = function()
            rootViewManager:exit()
        end
    },
    {
        -- 容器布局，用于放置两个View
        FrameLayout,
        id = "containerLayout",
        layout_width = '300dp',
        layout_height = '600dp',
        layout_marginTop = '20dp',
        gravity = 'center',
        {
            -- View 1 (较小) - 居中显示
            LinearLayout,
            id = "view1Layout",
            layout_width = '50dp',
            layout_height = '50dp',
            backgroundColor = 0xFFFF0000,
            gravity = 'center',
            layout_gravity = 'center',
            onClick = function()
                if not isAnimating then
                    animateToView2()
                end
            end,
            {
                TextView,
                text = 'View 1\n点击变大',
                textColor = 0xFFFFFFFF,
                textSize = '10sp',
                gravity = 'center'
            }
        },
        {
            -- View 2 (较大) - 居中显示
            LinearLayout,
            id = "view2Layout",
            layout_width = '300dp',
            layout_height = '600dp',
            backgroundColor = 0xFF0000FF,
            gravity = 'center',
            layout_gravity = 'center',
            visibility = 'gone',
            onClick = function()
                if not isAnimating then
                    animateToView1()
                end
            end,
            {
                TextView,
                text = 'View 2\n点击变小',
                textColor = 0xFFFFFFFF,
                textSize = '16sp',
                gravity = 'center'
            }
        }
    }
})

-- 动画状态标志
local isAnimating = false

-- 过渡到View2 (由小变大)
function animateToView2()
    if isAnimating then return end
    isAnimating = true
    
    -- 先显示view2但设置为透明
    view2Layout:setVisibility(0)
    view2Layout:setAlpha(1.0)
    
    -- 计算中心点位置
    local centerX = containerLayout:getWidth() / 2
    local centerY = containerLayout:getHeight() / 2
    
    -- 获取view1的位置和大小
    local view1Location = {0, 0}
    view1Layout:getLocationOnScreen(view1Location)
    local view1X = view1Location[1]
    local view1Y = view1Location[2]
    local view1Width = view1Layout:getWidth()
    local view1Height = view1Layout:getHeight()
    
    -- 计算初始缩放比例和位置偏移
    local initialScaleX = view1Width / view2Layout:getWidth()
    local initialScaleY = view1Height / view2Layout:getHeight()
    
    -- 设置view2的初始状态（与view1相同位置和大小）
    view2Layout:setScaleX(initialScaleX)
    view2Layout:setScaleY(initialScaleY)
    view2Layout:setTranslationX(view1X - (centerX - view1Width/2))
    view2Layout:setTranslationY(view1Y - (centerY - view1Height/2))
    
    -- 创建动画 - 使用正确的 ObjectAnimator 创建方式
    local scaleXAnim = luajava.bindClass("android.animation.ObjectAnimator").ofFloat(view2Layout, "scaleX", initialScaleX, 1.0)
    local scaleYAnim = luajava.bindClass("android.animation.ObjectAnimator").ofFloat(view2Layout, "scaleY", initialScaleY, 1.0)
    local transXAnim = luajava.bindClass("android.animation.ObjectAnimator").ofFloat(view2Layout, "translationX", view2Layout:getTranslationX(), 0)
    local transYAnim = luajava.bindClass("android.animation.ObjectAnimator").ofFloat(view2Layout, "translationY", view2Layout:getTranslationY(), 0)
    
    -- view1的淡出动画
    local view1AlphaAnim = luajava.bindClass("android.animation.ObjectAnimator").ofFloat(view1Layout, "alpha", 1.0, 0.0)
    
    -- 创建动画集合
    local animatorSet = luajava.newInstance("android.animation.AnimatorSet")
    
    -- 设置动画时长
    local duration = 500
    scaleXAnim:setDuration(duration)
    scaleYAnim:setDuration(duration)
    transXAnim:setDuration(duration)
    transYAnim:setDuration(duration)
    view1AlphaAnim:setDuration(duration)
    
    -- 播放动画
    animatorSet:playTogether(scaleXAnim, scaleYAnim, transXAnim, transYAnim, view1AlphaAnim)
    animatorSet:start()
    
    -- 动画监听
    animatorSet:addListener(luajava.createProxy('android.animation.Animator$AnimatorListener', {
        onAnimationStart = function(animation) end,
        onAnimationEnd = function(animation)
            view1Layout:setVisibility(8)
            view1Layout:setAlpha(1.0)
            view2Layout:setScaleX(1.0)
            view2Layout:setScaleY(1.0)
            view2Layout:setTranslationX(0)
            view2Layout:setTranslationY(0)
            isAnimating = false
        end,
        onAnimationCancel = function(animation) end,
        onAnimationRepeat = function(animation) end
    }))
end

-- 过渡到View1 (由大变小)
function animateToView1()
    if isAnimating then return end
    isAnimating = true
    
    -- 先显示view1但设置为透明
    view1Layout:setVisibility(0)
    view1Layout:setAlpha(0.0)
    
    -- 计算中心点位置
    local centerX = containerLayout:getWidth() / 2
    local centerY = containerLayout:getHeight() / 2
    
    -- 获取view2的位置和大小
    local view2Location = {0, 0}
    view2Layout:getLocationOnScreen(view2Location)
    local view2X = view2Location[1]
    local view2Y = view2Location[2]
    local view2Width = view2Layout:getWidth()
    local view2Height = view2Layout:getHeight()
    
    -- 计算目标缩放比例和位置偏移
    local targetScaleX = view1Layout:getWidth() / view2Width
    local targetScaleY = view1Layout:getHeight() / view2Height
    
    -- 设置view1的初始状态（与view2相同位置和大小）
    view1Layout:setScaleX(1.0 / targetScaleX)
    view1Layout:setScaleY(1.0 / targetScaleY)
    view1Layout:setTranslationX(view2X - (centerX - view2Width/2))
    view1Layout:setTranslationY(view2Y - (centerY - view2Height/2))
    
    -- 创建动画 - 使用正确的 ObjectAnimator 创建方式
    local scaleXAnim = luajava.bindClass("android.animation.ObjectAnimator").ofFloat(view1Layout, "scaleX", view1Layout:getScaleX(), 1.0)
    local scaleYAnim = luajava.bindClass("android.animation.ObjectAnimator").ofFloat(view1Layout, "scaleY", view1Layout:getScaleY(), 1.0)
    local transXAnim = luajava.bindClass("android.animation.ObjectAnimator").ofFloat(view1Layout, "translationX", view1Layout:getTranslationX(), 0)
    local transYAnim = luajava.bindClass("android.animation.ObjectAnimator").ofFloat(view1Layout, "translationY", view1Layout:getTranslationY(), 0)
    
    -- view1的淡入动画
    local view1AlphaAnim = luajava.bindClass("android.animation.ObjectAnimator").ofFloat(view1Layout, "alpha", 0.0, 1.0)
    
    -- view2的淡出动画
    local view2AlphaAnim = luajava.bindClass("android.animation.ObjectAnimator").ofFloat(view2Layout, "alpha", 1.0, 0.0)
    
    -- 创建动画集合
    local animatorSet = luajava.newInstance("android.animation.AnimatorSet")
    
    -- 设置动画时长
    local duration = 500
    scaleXAnim:setDuration(duration)
    scaleYAnim:setDuration(duration)
    transXAnim:setDuration(duration)
    transYAnim:setDuration(duration)
    view1AlphaAnim:setDuration(duration)
    view2AlphaAnim:setDuration(duration)
    
    -- 播放动画
    animatorSet:playTogether(scaleXAnim, scaleYAnim, transXAnim, transYAnim, view1AlphaAnim, view2AlphaAnim)
    animatorSet:start()
    
    -- 动画监听
    animatorSet:addListener(luajava.createProxy('android.animation.Animator$AnimatorListener', {
        onAnimationStart = function(animation) end,
        onAnimationEnd = function(animation)
            view2Layout:setVisibility(8)
            view2Layout:setAlpha(1.0)
            view1Layout:setScaleX(1.0)
            view1Layout:setScaleY(1.0)
            view1Layout:setTranslationX(0)
            view1Layout:setTranslationY(0)
            isAnimating = false
        end,
        onAnimationCancel = function(animation) end,
        onAnimationRepeat = function(animation) end
    }))
end

-- 绑定View之后的调用函数默认第一个参数就是该View
rootViewManager = windowManager:bindView(rootView)

-- 等价于 windowManager:addView(rootView)
rootViewManager:addView()

-- 设置可以移动
rootViewManager:setMoveable(true)

gg.setVisible(false)


-- 等待悬浮窗退出
rootViewManager:wait()